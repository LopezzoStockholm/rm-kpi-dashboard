    """Sammanfattning av blocker-status for dashboard."""
    stats = run_psql(RM_CENTRAL_DB, """
        SELECT
            COUNT(*) FILTER (WHERE status = 'active') as active_count,
            COUNT(*) FILTER (WHERE status = 'active' AND follow_up_date <= CURRENT_DATE) as overdue_count,
            COUNT(*) FILTER (WHERE status = 'active' AND escalated = true) as escalated_count,
            COUNT(*) FILTER (WHERE status = 'active' AND follow_up_date BETWEEN CURRENT_DATE AND CURRENT_DATE + 3) as due_soon_count,
            COUNT(*) FILTER (WHERE status = 'resolved' AND resolved_at >= CURRENT_DATE - 7) as resolved_week
        FROM task_blocker
    """)
    return {"ok": True, "summary": stats[0] if stats else {}}


# ============================================================================
# External Task Ingest — skalbar ingress för WA, Teams, email, API
# ============================================================================

class ExternalTaskIngest(BaseModel):
    """Generisk modell för tasks från externa system.
    Alla fält är optional utom title och source_system."""
    title: str
    description: Optional[str] = None
    task_type: str = "action"
    context: Optional[str] = None
    priority: int = 2
    # Avsändare — löses upp via telefon, email eller namn
    sender_phone: Optional[str] = None   # "46707830063" eller "0707830063"
    sender_email: Optional[str] = None
    sender_name: Optional[str] = None
    # Tilldelning — direkt eller via parsad data
    assignee_email: Optional[str] = None
    assignee_name: Optional[str] = None
    # Projekt
    project_code: Optional[str] = None
    project_name: Optional[str] = None
    # Metadata
    due_date: Optional[str] = None
    source_system: str  # "whatsapp", "teams", "email", "api", "n8n"
    source_message_id: Optional[str] = None
    source_channel: Optional[str] = None  # kanal/chat/tråd
    # Auto-routing
    board_column: Optional[str] = None  # None = auto-bestäm
    company_id: Optional[str] = None
    company_name: Optional[str] = None
    contact_name: Optional[str] = None


def _normalize_phone(phone: str) -> str:
    """Normalisera telefonnummer till 46-format utan +."""
    digits = "".join(c for c in phone if c.isdigit())
    if digits.startswith("0") and len(digits) == 10:
        digits = "46" + digits[1:]
    return digits


def _lookup_user_by_phone(phone: str):
    """Slå upp portal_user via telefonnummer. Returnerar dict eller None."""
    normalized = _normalize_phone(phone)
    # Testa mot alla möjliga format
    candidates = [normalized]
    if normalized.startswith("46"):
        candidates.append("0" + normalized[2:])  # 0707830063
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT display_name, email, role, phone
        FROM portal_user
        WHERE active = true
          AND (replace(phone, '+', '') = '{_sq(normalized)}'
               OR phone = '{_sq(candidates[-1] if len(candidates) > 1 else normalized)}')
        LIMIT 1
    """)
    return rows[0] if rows else None


def _lookup_user_by_name(name: str):
    """Slå upp portal_user via display_name (fuzzy). Returnerar dict eller None."""
    if not name:
        return None
    name_clean = name.strip()
    try:
        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT id, display_name, email, role, phone
            FROM portal_user
            WHERE LOWER(display_name) = LOWER('{_sq(name_clean)}')
            LIMIT 1
        """)
        if rows:
            return rows[0]
        # Fuzzy: sök på förnamn
        first_name = name_clean.split()[0] if ' ' in name_clean else name_clean
        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT id, display_name, email, role, phone
            FROM portal_user
            WHERE LOWER(display_name) LIKE LOWER('{_sq(first_name)}%%')
            LIMIT 1
        """)
        return rows[0] if rows else None
    except Exception as e:
        print(f"_lookup_user_by_name error: {e}")
        return None


def _lookup_user_by_email(email: str):
    """Slå upp portal_user via email."""
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT display_name, email, role, phone
        FROM portal_user
        WHERE active = true AND email = '{_sq(email)}'
        LIMIT 1
    """)
    return rows[0] if rows else None


@app.post("/api/hub/tasks/ingest")
async def hub_ingest_external_task(body: ExternalTaskIngest, request: Request):
    """Skalbar extern task-ingress. Autentiseras via intern token.
    
    Löser upp avsändare via telefon/email → portal_user.
    Bestämmer board_column automatiskt baserat på tilldelning.
    Deduplicerar via source_system + source_message_id.
    """
    _verify_internal(request)
    
    try:
        # ── Deduplicate ──
        if body.source_message_id:
            existing = run_psql(RM_CENTRAL_DB, f"""
                SELECT id FROM rm_task
                WHERE external_system = '{_sq(body.source_system)}'
                  AND external_id = '{_sq(body.source_message_id)}'
                LIMIT 1
            """)
            if existing:
                return {"ok": True, "id": str(existing[0]["id"]), "deduplicated": True}

        # ── Resolve sender → portal_user ──
        sender_user = None
        if body.sender_phone:
            sender_user = _lookup_user_by_phone(body.sender_phone)
        if not sender_user and body.sender_email:
            sender_user = _lookup_user_by_email(body.sender_email)

        sender_display = (sender_user or {}).get("display_name") if sender_user else body.sender_name
        sender_email = (sender_user or {}).get("email") if sender_user else body.sender_email

        # ── Resolve assignee ──
        assignee_email = body.assignee_email
        assignee_name = body.assignee_name
        
        # Lookup: namn → email om email saknas
        if assignee_name and not assignee_email:
            assignee_user = _lookup_user_by_name(assignee_name)
            if assignee_user:
                assignee_email = assignee_user.get("email")
                assignee_name = assignee_user.get("display_name", assignee_name)
        
        if not assignee_email and not assignee_name:
            # Ingen tilldelning → tilldela avsändaren
            assignee_email = sender_email
            assignee_name = sender_display

        # ── Auto-routing: board_column ──
        board_column = body.board_column or "inbox"
        if assignee_email and sender_email and assignee_email != sender_email:
            board_column = "waiting"

        # ── Insert ──
        new_id = execute(
            """INSERT INTO rm_task
               (company_code, title, description, task_type, context, priority,
                assignee_name, assignee_email, created_by,
                project_code, project_name,
                board_column, due_date,
                source, external_system, external_id,
                company_id, company_name, contact_name)
               VALUES ('RM', %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s::uuid, %s, %s)
               RETURNING id""",
            (
                body.title, body.description, body.task_type, body.context, body.priority,
                assignee_name, assignee_email, sender_email or sender_display,
                body.project_code, body.project_name,
                board_column, body.due_date,
                body.source_system, body.source_system, body.source_message_id,
                body.company_id or None, body.company_name, body.contact_name
            ),
            returning=True
        )

        if new_id is None:
            raise HTTPException(status_code=500, detail="Kunde inte skapa task")

        _log_task_activity(str(new_id), "created",
                           new_value=f"via {body.source_system}" + (f" från {sender_display}" if sender_display else ""),
                           actor="system")

        return {"ok": True, "id": str(new_id), "board_column": board_column,
                "assignee_email": assignee_email, "assignee_name": assignee_name,
                "deduplicated": False}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/users/by-phone/{phone}")
async def hub_user_by_phone(phone: str, request: Request):
    """Intern: slå upp portal_user via telefonnummer."""
    _verify_internal(request)
    user = _lookup_user_by_phone(phone)
    if not user:
        raise HTTPException(status_code=404, detail="Ingen användare med det numret")
    return {"ok": True, "user": user}


