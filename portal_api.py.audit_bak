# --- Key Activities (Howwe-inspirerat: veckocommits kopplade till rocks) ---

@app.get("/api/key-activities")
async def get_key_activities(rock_id: Optional[int] = None, owner: Optional[str] = None, active: bool = True, user: dict = Depends(get_current_user)):
    """Hamta key activities, filtrera pa rock eller agare. Icke-VD ser bara sina egna."""
    # Rollfiltrering: icke-VD tvingas till sin egen owner_alias
    if not has_perm(user, "admin.scaling_up") and not owner:
        owner = user.get("owner_alias")
    conds = []
    params = []
    if active:
        conds.append("ka.active=true")
    if rock_id is not None:
        conds.append("ka.rock_id=%s")
        params.append(rock_id)
    if owner:
        conds.append("ka.owner=%s")
        params.append(owner)
    where = (" WHERE " + " AND ".join(conds)) if conds else ""
    rows = query_dicts(
        f"""SELECT ka.*, r.title AS rock_title, r.quarter, r.status AS rock_status
            FROM key_activity ka
            JOIN quarterly_rock r ON r.id = ka.rock_id
            {where}
            ORDER BY ka.rock_id, ka.sort_order, ka.id""",
        params if params else None
    )
    return {"activities": rows}


@app.post("/api/key-activities")
async def create_key_activity(ka: KeyActivityCreate):
    """Skapa en ny key activity kopplad till en rock."""

    require_perm(user, "admin.scaling_up")
    new_id = execute(
        """INSERT INTO key_activity (rock_id, title, owner, role, frequency, target_per_period, unit, sort_order)
           VALUES (%s, %s, %s, %s, %s, %s, %s, %s) RETURNING id""",
        (ka.rock_id, ka.title, ka.owner, ka.role, ka.frequency, ka.target_per_period, ka.unit, ka.sort_order),
        returning=True
    )
    if new_id is None:
        raise HTTPException(status_code=500, detail="Kunde inte skapa key activity")
    return {"id": new_id}


@app.patch("/api/key-activities/{ka_id}")
async def update_key_activity(ka_id: int, update: KeyActivityUpdate):
    """Uppdatera en key activity."""
    sets = []
    params = []
    for field in ["title", "owner", "role", "frequency", "target_per_period", "unit", "active", "sort_order"]:
        val = getattr(update, field, None)
        if val is not None:
            sets.append(f"{field}=%s")
            params.append(val)
    if not sets:
        raise HTTPException(status_code=400, detail="Inget att uppdatera")
    sets.append("updated_at=NOW()")
    params.append(ka_id)
    execute(f"UPDATE key_activity SET {', '.join(sets)} WHERE id=%s", params)
    return {"ok": True, "id": ka_id}


@app.delete("/api/key-activities/{ka_id}")
async def delete_key_activity(ka_id: int):
    """Soft-delete (active=false) en key activity."""

    require_perm(user, "admin.scaling_up")
    execute("UPDATE key_activity SET active=false, updated_at=NOW() WHERE id=%s", (ka_id,))
    return {"ok": True, "id": ka_id}


# --- Weekly Acceleration Meeting (Howwe-modell: commitments per vecka) ---

def _current_iso_week() -> str:
    from datetime import datetime as _dt
    y, w, _ = _dt.utcnow().isocalendar()
    return f"{y}-W{w:02d}"


@app.get("/api/meetings/weekly")
async def get_weekly_commitments(week: Optional[str] = None, owner: Optional[str] = None, user: dict = Depends(get_current_user)):
    """Hamta veckans commitments. Om week saknas anvands denna vecka (ISO). Icke-VD ser bara sina egna."""
    wk = week or _current_iso_week()
    # Rollfiltrering: icke-VD tvingas till sin egen owner_alias
    if not has_perm(user, "admin.scaling_up") and not owner:
        owner = user.get("owner_alias")
    conds = ["mc.iso_week=%s"]
    params = [wk]
    if owner:
        conds.append("mc.owner=%s")
        params.append(owner)
    where = " AND ".join(conds)
    rows = query_dicts(
        f"""SELECT mc.*,
                   ka.title AS activity_title,
                   ka.target_per_period,
                   ka.unit,
                   ka.frequency,
                   ka.role AS activity_role,
                   r.id AS rock_id,
                   r.title AS rock_title,
                   r.quarter
            FROM meeting_commitment mc
            JOIN key_activity ka ON ka.id = mc.key_activity_id
            JOIN quarterly_rock r ON r.id = ka.rock_id
            WHERE {where}
            ORDER BY mc.owner, r.id, ka.sort_order, ka.id""",
        params
    )
    # Summering per owner
    summary: dict = {}
    for r in rows:
        o = r["owner"]
        if o not in summary:
            summary[o] = {"total": 0, "completed": 0, "committed": 0, "actual": 0, "blockers": 0}
        summary[o]["total"] += 1
        if r["completed"]:
            summary[o]["completed"] += 1
        summary[o]["committed"] += r["committed_count"] or 0
        summary[o]["actual"] += r["actual_count"] or 0
        if r["blocker"]:
            summary[o]["blockers"] += 1
    return {"week": wk, "commitments": rows, "summary": summary}


@app.post("/api/meetings/weekly/generate")
async def generate_weekly_commitments(week: Optional[str] = None):
    """Skapa tomma commitment-rader för veckan från alla aktiva key activities.
    Hoppar över (owner, key_activity_id, week)-kombinationer som redan finns."""
    wk = week or _current_iso_week()
    activities = query_dicts(
        """SELECT ka.id, ka.owner, ka.target_per_period
           FROM key_activity ka
           JOIN quarterly_rock r ON r.id = ka.rock_id
           WHERE ka.active=true AND ka.owner IS NOT NULL AND ka.owner != ''
             AND r.status != 'done'"""
    )
    created = 0
    for a in activities:
        result = execute(
            """INSERT INTO meeting_commitment (iso_week, key_activity_id, owner, committed_count)
               VALUES (%s, %s, %s, %s)
               ON CONFLICT (iso_week, key_activity_id, owner) DO NOTHING
               RETURNING id""",
            (wk, a["id"], a["owner"], a["target_per_period"] or 1),
            returning=True
        )
        if result is not None:
            created += 1
    return {"ok": True, "week": wk, "created": created, "total_activities": len(activities)}


@app.patch("/api/meetings/commitment/{cid}")
async def update_commitment(cid: int, update: CommitmentUpdate):
    """Uppdatera en commitment (actual, committed, blocker, notes, completed)."""
    sets = []
    params = []
    # Anvand model_fields_set sa att null uttryckligen satt skriver over
    sent_fields = update.model_fields_set if hasattr(update, "model_fields_set") else set()
    for field in ["committed_count", "actual_count", "completed", "blocker", "notes"]:
        if field in sent_fields:
            val = getattr(update, field, None)
            sets.append(f"{field}=%s")
            params.append(val)
    if not sets:
        raise HTTPException(status_code=400, detail="Inget att uppdatera")
    sets.append("updated_at=NOW()")
    params.append(cid)
    execute(f"UPDATE meeting_commitment SET {', '.join(sets)} WHERE id=%s", params)
    # Auto-completed om actual >= committed och completed inte explicit satt (andra UPDATE efter nya varden satts)
    if update.completed is None and update.actual_count is not None:
        execute("UPDATE meeting_commitment SET completed = (actual_count >= committed_count AND committed_count > 0) WHERE id=%s", [cid])
    return {"ok": True, "id": cid}


@app.get("/api/meetings/hitrate")
async def get_hitrate(weeks: int = 8, owner: Optional[str] = None, user: dict = Depends(get_current_user)):
    """Hit-rate rullande N veckor per key activity, med per-vecka matris, streak och at_risk-flagga. Icke-VD ser bara sina egna."""
    # Rollfiltrering: icke-VD tvingas till sin egen owner_alias
    if not has_perm(user, "admin.scaling_up") and not owner:
        owner = user.get("owner_alias")
    where_owner = ""
    params = [weeks]
    if owner:
        where_owner = "AND mc.owner=%s"
        params.append(owner)
    # Hamta alla commitments senaste N veckor
    raw = query_dicts(
        f"""SELECT mc.owner,
                   ka.id AS key_activity_id,
                   ka.title AS activity_title,
                   r.title AS rock_title,
                   mc.iso_week,
                   mc.completed,
                   mc.committed_count,
                   mc.actual_count,
                   mc.blocker
            FROM meeting_commitment mc
            JOIN key_activity ka ON ka.id = mc.key_activity_id
            JOIN quarterly_rock r ON r.id = ka.rock_id
            WHERE mc.iso_week >= TO_CHAR(NOW() - (%s || ' weeks')::INTERVAL, 'IYYY-"W"IW')
              {where_owner}
            ORDER BY mc.iso_week DESC""",
        params
    )
    # Gruppera per (owner, key_activity_id) och bygg matris
    from collections import OrderedDict
    groups = OrderedDict()
    all_weeks = set()
    for r in raw:
        key = (r["owner"], r["key_activity_id"])
        all_weeks.add(r["iso_week"])
        if key not in groups:
            groups[key] = {
                "owner": r["owner"],
                "key_activity_id": r["key_activity_id"],
                "activity_title": r["activity_title"],
                "rock_title": r["rock_title"],
                "weeks_data": {},
            }
        groups[key]["weeks_data"][r["iso_week"]] = {
            "completed": r["completed"],
            "committed": r["committed_count"],
            "actual": r["actual_count"],
            "blocker": r["blocker"],
        }
    # Sortera veckor (nyast forst)
    sorted_weeks = sorted(all_weeks, reverse=True)
    # Bygg owner->role map for threshold-lookup
    owner_role_rows = query_dicts(
        "SELECT owner_alias, role FROM portal_user WHERE owner_alias IS NOT NULL AND active = TRUE"
    )
    owner_role_map = {r["owner_alias"]: r["role"] for r in owner_role_rows}
    # Resolver med cache per (ka_id, role)
    _thr_cache: dict = {}
    def resolve_hitrate_threshold(ka_id, row_owner):
        role = owner_role_map.get(row_owner)
        cache_key = (ka_id, role)
        if cache_key in _thr_cache:
            return _thr_cache[cache_key]
        res = query_dicts(
            "SELECT * FROM get_threshold(%s, %s, NULL, 'hitrate')",
            [ka_id, role]
        )
        thr = res[0] if res else {
            "green_at": 80, "yellow_at": 50, "window_weeks": 4,
            "min_data_points": 2, "at_risk_consecutive": 2,
            "direction": "higher_better", "resolved_scope": "fallback"
        }
        _thr_cache[cache_key] = thr
        return thr
    # Bygg output med streak, hit-rate, at-risk
    rows = []
    for g in groups.values():
        wd = g["weeks_data"]
        total = len(wd)
        completed = sum(1 for w in wd.values() if w["completed"])
        hit_rate = round(100.0 * completed / total) if total > 0 else 0
        # Threshold: cascade target->role->company->system
        thr = resolve_hitrate_threshold(g["key_activity_id"], g["owner"])
        window = int(thr["window_weeks"])
        green_at = float(thr["green_at"])
        yellow_at = float(thr["yellow_at"])
        min_data = int(thr["min_data_points"])
        # Streak: consecutive completed fran senaste veckan bakat
        streak = 0
        for w in sorted_weeks:
            if w in wd:
                if wd[w]["completed"]:
                    streak += 1
                else:
                    break
            else:
                break
        # Rolling window (ersatter hardkodade last_4)
        last_n = [wd[w]["completed"] for w in sorted_weeks[:window] if w in wd]
        last_n_pct = round(100.0 * sum(1 for c in last_n if c) / len(last_n)) if last_n else 0
        # At-risk: hit-rate under yellow OCH minst min_data veckors data
        at_risk = last_n_pct < yellow_at and len(last_n) >= min_data
        # Status
        if last_n_pct >= green_at:
            status = "green"
        elif last_n_pct >= yellow_at:
            status = "yellow"
        else:
            status = "red"
        # Timeline: lista per vecka (True/False/None) for senaste N veckor
        timeline = []
        for w in sorted_weeks[:weeks]:
            if w in wd:
                timeline.append({"week": w, "completed": wd[w]["completed"], "blocker": wd[w]["blocker"]})
            else:
                timeline.append({"week": w, "completed": None, "blocker": None})
        rows.append({
            "owner": g["owner"],
            "key_activity_id": g["key_activity_id"],
            "activity_title": g["activity_title"],
            "rock_title": g["rock_title"],
            "total_weeks": total,
            "completed_weeks": completed,
            "hit_rate_pct": hit_rate,
            "last_4w_pct": last_n_pct,
            "window_weeks": window,
            "streak": streak,
            "at_risk": at_risk,
            "status": status,
            "threshold_green": green_at,
            "threshold_yellow": yellow_at,
            "threshold_scope": thr.get("resolved_scope", "system:default"),
            "timeline": timeline,
        })
    # Sortera at-risk forst, sedan efter hit-rate
    rows.sort(key=lambda x: (not x["at_risk"], x["last_4w_pct"]))
    return {"weeks": weeks, "all_weeks": sorted_weeks[:weeks], "rows": rows}


# --- Meeting support ---

@app.get("/api/meeting/daily")
async def daily_huddle():
    """Data för daily huddle: stuck items, today tasks, critical numbers."""
    stuck_rocks = query_dicts(
        "SELECT id, title, owner, status, progress FROM quarterly_rock WHERE company_code='RM' AND status IN ('behind','at_risk') AND status != 'done' ORDER BY status DESC, progress",
    )
    # Overdue tasks (from planner_task)
    overdue_tasks = query_dicts(
        "SELECT id, title, assigned_to, due_date::text FROM planner_task WHERE status != 'completed' AND due_date < CURRENT_DATE ORDER BY due_date LIMIT 10",
    )
    # Red scorecard items (latest entry below target)
    red_metrics = query_dicts(
        """SELECT t.metric_name, t.target_value, t.unit, t.owner, e.actual_value, e.period
           FROM scorecard_target t
           JOIN LATERAL (
               SELECT actual_value, period FROM scorecard_entry WHERE target_id=t.id ORDER BY period DESC LIMIT 1
           ) e ON true
           WHERE t.active=true AND t.company_code='RM'
             AND ((t.is_green_above AND e.actual_value < t.target_value) OR (NOT t.is_green_above AND e.actual_value > t.target_value))
        """,
    )
    # Bank balance
    bank = query_one("SELECT balance FROM bank_balance WHERE company_code='RM' ORDER BY date DESC LIMIT 1")
    return {
        "stuck_rocks": stuck_rocks,
        "overdue_tasks": overdue_tasks,
        "red_metrics": red_metrics,
        "bank_balance": float(bank) if bank else None,
        "generated_at": datetime.now().isoformat()
    }




# ============================================================================
# Layout API — config-driven dashboard
# ============================================================================

@app.get("/api/layout")
async def get_layout(request: Request, user: dict = Depends(get_current_user), company: str = "RM"):
    """Get resolved layout for current user. 3-tier cascade: user > role > system default.
    VD can pass ?view_as=projektledare to preview another role's layout."""
    view_as = request.query_params.get("view_as")
    if view_as and has_perm(user, "admin.dashboard_layout") and view_as in ("vd", "ekonomi", "projektledare", "falt"):
        role = view_as
        # Skip personal layout when previewing another role
        username = None
    else:
        role = user["role"]
        username = user["username"]

    # Get user_id
    user_id = None
    if username:
        user_rows = run_psql(RM_CENTRAL_DB, f"SELECT id FROM portal_user WHERE username='{username}'")
        user_id = user_rows[0]["id"] if user_rows else None

    # Tier 1: Personal layout
    personal = []
    if user_id:
        personal = run_psql(RM_CENTRAL_DB, f"""
            SELECT dl.widget_key, dl.sort_order, dl.visible, dl.config,
                   dw.display_name, dw.component_name, dw.category, dw.requires_data
            FROM dashboard_layout dl
            JOIN dashboard_widget dw ON dw.widget_key = dl.widget_key AND dw.is_active = true
            WHERE dl.company_code='{company}' AND dl.user_id={user_id}
            ORDER BY dl.sort_order
        """)

    if personal:
        return {"source": "personal", "role": role, "widgets": personal}

    # Tier 2: Role-based layout
    role_layout = run_psql(RM_CENTRAL_DB, f"""
        SELECT dl.widget_key, dl.sort_order, dl.visible, dl.config,
               dw.display_name, dw.component_name, dw.category, dw.requires_data
        FROM dashboard_layout dl
        JOIN dashboard_widget dw ON dw.widget_key = dl.widget_key AND dw.is_active = true
        WHERE dl.company_code='{company}' AND dl.role='{role}' AND dl.user_id IS NULL
        ORDER BY dl.sort_order
    """)

    if role_layout:
        return {"source": "role", "role": role, "widgets": role_layout}

    # Tier 3: System default (from dashboard_widget.default_roles)
    system_default = run_psql(RM_CENTRAL_DB, f"""
        SELECT widget_key, default_sort_order as sort_order, true as visible, '{{}}'::text as config,
               display_name, component_name, category, requires_data
        FROM dashboard_widget
        WHERE is_active = true AND '{role}' = ANY(default_roles)
        ORDER BY default_sort_order
    """)

    return {"source": "system_default", "role": role, "widgets": system_default}


@app.get("/api/layout/widgets")
async def get_all_widgets(user: dict = Depends(get_current_user)):
    """Get all available widgets (for admin page)."""
    widgets = run_psql(RM_CENTRAL_DB, """
        SELECT widget_key, display_name, component_name, category,
               default_roles, default_sort_order, requires_data, is_active
        FROM dashboard_widget ORDER BY default_sort_order
    """)
    return {"widgets": widgets}


@app.get("/api/layout/role/{role}")
async def get_role_layout(role: str, user: dict = Depends(get_current_user), company: str = "RM"):
    """Get layout for a specific role (admin use)."""
    require_perm(user, "admin.dashboard_layout")

    layout = run_psql(RM_CENTRAL_DB, f"""
        SELECT dl.widget_key, dl.sort_order, dl.visible, dl.config,
               dw.display_name, dw.component_name, dw.category
        FROM dashboard_layout dl
        JOIN dashboard_widget dw ON dw.widget_key = dl.widget_key
        WHERE dl.company_code='{company}' AND dl.role='{role}' AND dl.user_id IS NULL
        ORDER BY dl.sort_order
    """)

    # If no role layout, return system defaults for this role
    if not layout:
        layout = run_psql(RM_CENTRAL_DB, f"""
            SELECT widget_key, default_sort_order as sort_order, true as visible,
                   '{{}}'::text as config, display_name, component_name, category
            FROM dashboard_widget
            WHERE is_active = true AND '{role}' = ANY(default_roles)
            ORDER BY default_sort_order
        """)

    return {"role": role, "source": "role" if layout else "system_default", "widgets": layout}


class LayoutItem(BaseModel):
    widget_key: str
    sort_order: int
    visible: bool = True
    config: Optional[dict] = None


class LayoutUpdate(BaseModel):
    widgets: List[LayoutItem]


@app.put("/api/layout/role/{role}")
async def update_role_layout(role: str, body: LayoutUpdate, user: dict = Depends(get_current_user), company: str = "RM"):
    """Set role layout (VD only). Replaces all widgets for this role."""
    require_perm(user, "admin.dashboard_layout")

    # Delete existing
    run_psql(RM_CENTRAL_DB, f"DELETE FROM dashboard_layout WHERE company_code='{company}' AND role='{role}' AND user_id IS NULL")

    # Insert new
    for w in body.widgets:
        cfg = json.dumps(w.config or {}).replace("'", "''")
        run_psql(RM_CENTRAL_DB, f"""
            INSERT INTO dashboard_layout (company_code, role, user_id, widget_key, sort_order, visible, config)
            VALUES ('{company}', '{role}', NULL, '{w.widget_key}', {w.sort_order}, {str(w.visible).lower()}, '{cfg}'::jsonb)
        """)

    return {"status": "updated", "role": role, "widget_count": len(body.widgets)}


@app.put("/api/layout")
async def update_personal_layout(body: LayoutUpdate, user: dict = Depends(get_current_user), company: str = "RM"):
    """Set personal layout for current user."""
    username = user["username"]
    user_rows = run_psql(RM_CENTRAL_DB, f"SELECT id FROM portal_user WHERE username='{username}'")
    if not user_rows:
        raise HTTPException(status_code=404, detail="User not found")
    user_id = user_rows[0]["id"]

    # Delete existing personal layout
    run_psql(RM_CENTRAL_DB, f"DELETE FROM dashboard_layout WHERE company_code='{company}' AND user_id={user_id}")

    # Insert new
    for w in body.widgets:
        cfg = json.dumps(w.config or {}).replace("'", "''")
        run_psql(RM_CENTRAL_DB, f"""
            INSERT INTO dashboard_layout (company_code, role, user_id, widget_key, sort_order, visible, config)
            VALUES ('{company}', '{user['role']}', {user_id}, '{w.widget_key}', {w.sort_order}, {str(w.visible).lower()}, '{cfg}'::jsonb)
        """)

    return {"status": "updated", "source": "personal", "widget_count": len(body.widgets)}


@app.delete("/api/layout")
async def reset_personal_layout(user: dict = Depends(get_current_user), company: str = "RM"):
    """Reset personal layout (fall back to role default)."""
    username = user["username"]
    user_rows = run_psql(RM_CENTRAL_DB, f"SELECT id FROM portal_user WHERE username='{username}'")
    if not user_rows:
        raise HTTPException(status_code=404, detail="User not found")
    user_id = user_rows[0]["id"]

    run_psql(RM_CENTRAL_DB, f"DELETE FROM dashboard_layout WHERE company_code='{company}' AND user_id={user_id}")
    return {"status": "reset", "source": "role_default"}


# ============================================================================
# ÄTA API — replicated from whatsapp_webhook for dashboard access
# ============================================================================

@app.get("/api/ata")
async def list_ata(
    user: dict = Depends(get_current_user),
    status: Optional[str] = None,
    project: Optional[str] = None,
    company: str = "RM"
):
    """List ÄTA register with optional filters. Projektledare ser bara sina egna projekts ÄTA."""
    where = [f"company_code='{company}'"]
    if status:
        where.append(f"status='{status}'")
    if project:
        where.append(f"project_name ILIKE '%{project}%'")

    # Role-based filtering: projektledare sees only their projects by matching
    # project_name against next_project_economy.project_leader = current user.
    if not has_perm(user, "ata.read_all"):
        name = (user.get("name") or "").replace("'", "''")
        where.append(
            f"project_name IN ("
            f"SELECT DISTINCT project_name FROM next_project_economy "
            f"WHERE project_manager ILIKE '%{name}%'"
            f")"
        )

    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_number, project_code, project_name, description,
               estimated_amount, final_amount, status, category,
               reported_by, decided_by, decided_at::text, customer_approved,
               customer_email, sent_to_customer_at::text, sent_by,
               customer_decision, customer_decision_at::text,
               customer_rejection_reason,
               photo_urls::text, created_at::text, updated_at::text
        FROM ata_register
        WHERE {' AND '.join(where)}
        ORDER BY created_at DESC
        LIMIT 50
    """)
    return {"ata_items": rows, "count": len(rows), "role": user.get("role")}


@app.get("/api/ata/summary")
async def ata_summary(user: dict = Depends(get_current_user), company: str = "RM"):
    """ÄTA summary: counts by status, total amounts."""
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT status,
               COUNT(*) as count,
               COALESCE(SUM(estimated_amount),0) as estimated_total,
               COALESCE(SUM(final_amount),0) as final_total
        FROM ata_register
        WHERE company_code='{company}'
        GROUP BY status
    """)
    total = run_psql(RM_CENTRAL_DB, f"""
        SELECT COUNT(*) as total,
               COALESCE(SUM(estimated_amount),0) as estimated_total,
               COALESCE(SUM(final_amount),0) as final_total,
               COUNT(*) FILTER (WHERE customer_approved = true) as approved_count
        FROM ata_register WHERE company_code='{company}'
    """)
    return {"by_status": rows, "totals": total[0] if total else {}}


@app.patch("/api/ata/{ata_id}")
async def update_ata_status(ata_id: int, request: Request, user: dict = Depends(get_current_user)):
    """Update ÄTA status, amount, etc. Valid statuses: reported, approved_internal,
    rejected, ordered, signed, invoiced. Sets decided_by from authenticated user."""
    data = await request.json()
    allowed = ['status', 'final_amount', 'estimated_amount', 'project_code', 'project_name',
               'description', 'customer_approved', 'invoice_number', 'notes']
    valid_statuses = {'reported', 'approved_internal', 'rejected', 'sent_to_customer', 'ordered', 'signed', 'invoiced', 'pending_project'}

    if 'status' in data and data['status'] not in valid_statuses:
        raise HTTPException(status_code=400, detail=f"Invalid status. Must be one of: {sorted(valid_statuses)}")

    sets = []
    for key in allowed:
        if key in data:
            val = data[key]
            if val is None:
                sets.append(f"{key} = NULL")
            elif isinstance(val, bool):
                sets.append(f"{key} = {'true' if val else 'false'}")
            elif isinstance(val, (int, float)):
                sets.append(f"{key} = {val}")
            else:
                safe_val = str(val).replace("'", "''")
                sets.append(f"{key} = '{safe_val}'")

    # Auto-capture decided_by on internal approval/rejection from current user
    if data.get('status') in ('approved_internal', 'rejected'):
        decider = (user.get('name') or user.get('email') or 'unknown').replace("'", "''")
        sets.append(f"decided_by = '{decider}'")
        sets.append("decided_at = NOW()")
    if data.get('customer_approved'):
        sets.append("customer_approved_at = NOW()")

    sets.append("updated_at = NOW()")

    result = run_psql(RM_CENTRAL_DB, f"""
        UPDATE ata_register SET {', '.join(sets)} WHERE id = {ata_id}
        RETURNING ata_number, status
    """)
    if result:
        # Auto-archive PDF version on any state change
        try:
            from ata_pdf_archive import persist_ata_pdf_version
            trigger = data.get('status') or 'edit'
            user_name = user.get('name') or user.get('email') or 'system'
            persist_ata_pdf_version(ata_id, trigger_event=trigger, user_name=user_name)
        except Exception as _pe:
            import logging
            logging.getLogger(__name__).warning(f"PDF archive failed for ata_id={ata_id}: {_pe}")
        return {"status": "updated", "ata_number": result[0].get("ata_number"), "new_status": result[0].get("status")}
    raise HTTPException(status_code=404, detail="ÄTA not found")


@app.get("/api/ata/{ata_id}/pdf")
async def generate_ata_pdf(ata_id: int, user: dict = Depends(get_current_user)):
    """Generate a PDF for the ÄTA suitable for sending to the beställare."""
    from fastapi.responses import Response
    from io import BytesIO
    from reportlab.lib.pagesizes import A4
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.lib.units import mm
    from reportlab.lib import colors
    from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, Image
    from datetime import datetime

    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_number, project_code, project_name, description,
               estimated_amount, status, reported_by, decided_by, decided_at::text,
               created_at::text, notes, company_code
        FROM ata_register WHERE id = {ata_id}
    """)
    if not rows:
        raise HTTPException(status_code=404, detail="ÄTA not found")
    ata = rows[0]

    # Look up project leader + customer from next_project_economy
    proj_name = (ata.get("project_name") or "").replace("'", "''")
    proj_info = run_psql(RM_CENTRAL_DB, f"""
        SELECT project_manager, customer_name
        FROM next_project_economy
        WHERE project_name = '{proj_name}'
        LIMIT 1
    """) if proj_name else []
    project_leader = proj_info[0].get("project_manager") if proj_info else ""
    customer_name = proj_info[0].get("customer_name") if proj_info else ""

    # Build PDF
    buf = BytesIO()
    doc = SimpleDocTemplate(buf, pagesize=A4, leftMargin=20*mm, rightMargin=20*mm,
                             topMargin=18*mm, bottomMargin=18*mm,
                             title=f"ÄTA {ata['ata_number']}")
    styles = getSampleStyleSheet()
    h_style = ParagraphStyle('H', parent=styles['Heading1'], fontSize=18, textColor=colors.HexColor('#0D1117'), spaceAfter=6)
    sub_style = ParagraphStyle('Sub', parent=styles['Normal'], fontSize=10, textColor=colors.HexColor('#6E7681'), spaceAfter=14)
    label_style = ParagraphStyle('Label', parent=styles['Normal'], fontSize=9, textColor=colors.HexColor('#6E7681'), spaceAfter=2)
    value_style = ParagraphStyle('Value', parent=styles['Normal'], fontSize=11, textColor=colors.HexColor('#0D1117'), spaceAfter=10)
    body_style = ParagraphStyle('Body', parent=styles['Normal'], fontSize=10, leading=14, textColor=colors.HexColor('#0D1117'))

    story = []

    # Header
    story.append(Paragraph("RM Entreprenad och Fasad AB", ParagraphStyle('Company', parent=styles['Normal'], fontSize=9, textColor=colors.HexColor('#F0883E'))))
    story.append(Paragraph(f"Beställning av ÄTA-arbete — {ata['ata_number']}", h_style))
    date_str = datetime.fromisoformat(ata['created_at'].replace('+00', '+00:00')).strftime("%Y-%m-%d") if ata.get('created_at') else ""
    story.append(Paragraph(f"Inkom: {date_str} &nbsp;&nbsp;•&nbsp;&nbsp; Org.nr 559251-1462", sub_style))

    # Meta table
    meta = [
        ["Projekt", f"{ata.get('project_code') or '—'} &nbsp;{ata.get('project_name') or ''}"],
        ["Beställare", customer_name or "—"],
        ["Projektledare (RM)", project_leader or "—"],
        ["Rapporterad av (fält)", ata.get('reported_by') or "—"],
        ["Belopp (uppskattat)", f"{int(ata['estimated_amount']):,} kr".replace(",", " ") if ata.get('estimated_amount') else "Tidersättning / enligt ÅF-pris"],
    ]
    meta_tbl = Table([[Paragraph(k, label_style), Paragraph(v, value_style)] for k, v in meta], colWidths=[45*mm, 120*mm])
    meta_tbl.setStyle(TableStyle([
        ("VALIGN", (0,0), (-1,-1), "TOP"),
        ("BOTTOMPADDING", (0,0), (-1,-1), 4),
    ]))
    story.append(meta_tbl)
    story.append(Spacer(1, 10))

    # Description
    story.append(Paragraph("Beskrivning av arbetet", ParagraphStyle('H2', parent=styles['Heading2'], fontSize=12, textColor=colors.HexColor('#0D1117'), spaceAfter=6)))
    story.append(Paragraph((ata.get('description') or '').replace('\n', '<br/>'), body_style))
    story.append(Spacer(1, 14))

    # Contract reference
    ref_box = Table([[Paragraph(
        "<b>Avtalsreferens:</b> Denna ÄTA är en beställning av tillkommande arbete enligt gällande entreprenadavtal "
        "(ABS 18 / AB 04 / ABT 06). Arbete påbörjas först efter skriftligt godkännande från beställaren "
        "(signatur nedan eller svar via e-post). Uppskattat belopp är preliminärt och regleras enligt faktiskt utfört arbete "
        "samt avtalade priser.", body_style
    )]], colWidths=[165*mm])
    ref_box.setStyle(TableStyle([
        ("BACKGROUND", (0,0), (-1,-1), colors.HexColor('#FFF8E7')),
        ("BOX", (0,0), (-1,-1), 0.5, colors.HexColor('#E0C068')),
        ("LEFTPADDING", (0,0), (-1,-1), 10),
        ("RIGHTPADDING", (0,0), (-1,-1), 10),
        ("TOPPADDING", (0,0), (-1,-1), 8),
        ("BOTTOMPADDING", (0,0), (-1,-1), 8),
    ]))
    story.append(ref_box)
    story.append(Spacer(1, 22))

    # Signature block
    story.append(Paragraph("Godkännande — beställaren", ParagraphStyle('H2b', parent=styles['Heading2'], fontSize=12, textColor=colors.HexColor('#0D1117'), spaceAfter=10)))
    sig_tbl = Table([
        ["", "", ""],
        ["Underskrift", "Namnförtydligande", "Datum"],
    ], colWidths=[65*mm, 55*mm, 45*mm], rowHeights=[24*mm, 6*mm])
    sig_tbl.setStyle(TableStyle([
        ("LINEABOVE", (0,1), (-1,1), 0.5, colors.HexColor('#0D1117')),
        ("FONTSIZE", (0,1), (-1,1), 8),
        ("TEXTCOLOR", (0,1), (-1,1), colors.HexColor('#6E7681')),
        ("ALIGN", (0,1), (-1,1), "LEFT"),
    ]))
    story.append(sig_tbl)
    story.append(Spacer(1, 20))
    story.append(Paragraph(
        f"Alternativt: svara på mejlet med denna PDF bifogad med texten <b>\"Godkänt {ata['ata_number']}\"</b> "
        "så arkiveras svaret som beställarens godkännande.",
        ParagraphStyle('Fine', parent=styles['Normal'], fontSize=8, textColor=colors.HexColor('#6E7681'), leading=11)
    ))

    doc.build(story)
    pdf_bytes = buf.getvalue()

    return Response(
        content=pdf_bytes,
        media_type="application/pdf",
        headers={"Content-Disposition": f'inline; filename="{ata["ata_number"]}.pdf"'}
    )


@app.get("/api/ata/documents")
async def list_ata_documents(
    user: dict = Depends(get_current_user),
    project_code: Optional[str] = None,
    status: Optional[str] = None,
    from_date: Optional[str] = None,
    to_date: Optional[str] = None,
    limit: int = 200
):
    """List all archived ÄTA PDF versions across the company.
    Filters: project_code, status (state_at_generation), from_date/to_date (generated_at).
    Returns newest first."""
    where = ["1=1"]
    if project_code:
        safe = project_code.replace("'", "''")
        where.append(f"v.project_code = '{safe}'")
    if status:
        safe = status.replace("'", "''")
        where.append(f"v.state_at_generation = '{safe}'")
    if from_date:
        safe = from_date.replace("'", "''")
        where.append(f"v.generated_at >= '{safe}'")
    if to_date:
        safe = to_date.replace("'", "''")
        where.append(f"v.generated_at <= '{safe}'")
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT v.id, v.ata_id, v.ata_number, v.project_code, v.project_name,
               v.version, v.filepath, v.file_size_bytes, v.stamped,
               v.state_at_generation, v.amount_at_generation,
               v.trigger_event, v.generated_by, v.generated_at::text
        FROM ata_document_version v
        WHERE {' AND '.join(where)}
        ORDER BY v.generated_at DESC
        LIMIT {int(limit)}
    """)
    # Distinct project_codes for the filter dropdown
    projects = run_psql(RM_CENTRAL_DB, """
        SELECT DISTINCT project_number as project_code, project_name
        FROM ata_document_version
        WHERE project_number IS NOT NULL
        ORDER BY project_code
    """)
    return {"documents": rows, "count": len(rows), "projects": projects}


@app.get("/api/ata/{ata_id}/versions")
async def list_ata_versions(ata_id: int, user: dict = Depends(get_current_user)):
    """Return all archived PDF versions for a single ÄTA, newest first."""
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, version, filepath, file_size_bytes, stamped,
               state_at_generation, amount_at_generation, trigger_event,
               generated_by, generated_at::text
        FROM ata_document_version
        WHERE ata_id = {int(ata_id)}
        ORDER BY version DESC
    """)
    return {"versions": rows, "count": len(rows)}


@app.post("/api/ata/{ata_id}/archive-now")
async def archive_ata_now(ata_id: int, user: dict = Depends(get_current_user)):
    """Force-generate and archive a new PDF version for this ÄTA.

    require_perm(user, "ata.write")
    Useful for backfilling or forcing a regeneration."""
    from ata_pdf_archive import persist_ata_pdf_version
    user_name = user.get("name") or user.get("email") or "manual"
    result = persist_ata_pdf_version(ata_id, trigger_event="manual", user_name=user_name)
    if not result:
        raise HTTPException(status_code=404, detail="ÄTA not found or PDF build failed")
    return result


@app.get("/api/ata/documents/{version_id}/file")
async def get_ata_document_file(version_id: int, user: dict = Depends(get_current_user)):
    """Stream a specific archived PDF version."""
    from fastapi.responses import FileResponse
    from pathlib import Path as _P
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT filepath, ata_number, version
        FROM ata_document_version WHERE id = {int(version_id)}
    """)
    if not rows:
        raise HTTPException(status_code=404, detail="Version not found")
    rel = rows[0]["filepath"].lstrip("/")
    full = _P("/opt/rm-infra") / rel
    if not full.exists():
        raise HTTPException(status_code=404, detail=f"PDF file missing on disk: {rel}")
    filename = f'{rows[0]["ata_number"]}_v{rows[0]["version"]}.pdf'
    return FileResponse(str(full), media_type="application/pdf",
                        headers={"Content-Disposition": f'inline; filename="{filename}"'})









@app.get("/api/invoicing/history")
async def invoicing_history(
    user: dict = Depends(get_current_user),
    company: str = "RM",
    days: int = 90,
    project: str = None,
):
    """Lista alla fakturerade ATA (invoiced_at IS NOT NULL). Default senaste 90 dagar."""
    where = [f"company_code='{company}'", "invoiced_at IS NOT NULL",
             f"invoiced_at >= NOW() - INTERVAL '{int(days)} days'"]
    if project:
        safe_p = project.replace("'", "''")
        where.append(f"project_name ILIKE '%{safe_p}%'")
    if not has_perm(user, "invoices.read_all"):
        name = (user.get("name") or "").replace("'", "''")
        where.append(
            f"project_name IN ("
            f"SELECT DISTINCT project_name FROM next_project_economy "
            f"WHERE project_manager ILIKE '%{name}%'"
            f")"
        )
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_number, project_code, project_name, description,
               estimated_amount, final_amount, invoice_amount, invoice_number,
               invoiced_at::text, invoiced_by, status,
               customer_decision_at::text, decided_at::text
        FROM ata_register
        WHERE {' AND '.join(where)}
        ORDER BY invoiced_at DESC
    """)
    total = sum(float(r.get("invoice_amount") or r.get("final_amount") or r.get("estimated_amount") or 0) for r in rows)
    # Gruppera per month (YYYY-MM)
    by_month = {}
    by_project = {}
    for r in rows:
        inv = r.get("invoiced_at") or ""
        month = inv[:7] if inv else "unknown"
        amt = float(r.get("invoice_amount") or r.get("final_amount") or r.get("estimated_amount") or 0)
        by_month.setdefault(month, {"count": 0, "total": 0.0})
        by_month[month]["count"] += 1
        by_month[month]["total"] += amt
        pn = r.get("project_name") or "Utan projekt"
        by_project.setdefault(pn, {"count": 0, "total": 0.0})
        by_project[pn]["count"] += 1
        by_project[pn]["total"] += amt
    # Denna manad
    import datetime as _dt
    this_month = _dt.datetime.utcnow().strftime("%Y-%m")
    this_month_data = by_month.get(this_month, {"count": 0, "total": 0.0})
    return {
        "items": rows,
        "count": len(rows),
        "total_amount": total,
        "this_month": {"count": this_month_data["count"], "total": this_month_data["total"]},
        "by_month": by_month,
        "by_project": by_project,
    }


@app.get("/api/invoicing/queue")
async def invoicing_queue(user: dict = Depends(get_current_user), company: str = "RM"):
    """Lista alla godkanda ATA som ar redo att fakturera. Role-filtered pa samma satt som /api/ata."""
    where = [f"company_code='{company}'", "invoiced_at IS NULL",
             "((customer_decision='approve' AND status='ordered') OR status='approved_internal' OR status='signed')"]
    if not has_perm(user, "invoices.read_all"):
        name = (user.get("name") or "").replace("'", "''")
        where.append(
            f"project_name IN ("
            f"SELECT DISTINCT project_name FROM next_project_economy "
            f"WHERE project_manager ILIKE '%{name}%'"
            f")"
        )
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_number, project_code, project_name, description,
               estimated_amount, final_amount, status, customer_decision,
               customer_decision_at::text, decided_at::text,
               decided_by, created_at::text
        FROM ata_register
        WHERE {' AND '.join(where)}
        ORDER BY COALESCE(customer_decision_at, decided_at, created_at) ASC
    """)
    total = sum(float(r.get("final_amount") or r.get("estimated_amount") or 0) for r in rows)
    by_project = {}
    for r in rows:
        pn = r.get("project_name") or "Utan projekt"
        by_project.setdefault(pn, {"count": 0, "total": 0.0})
        by_project[pn]["count"] += 1
        by_project[pn]["total"] += float(r.get("final_amount") or r.get("estimated_amount") or 0)
    return {"items": rows, "count": len(rows), "total_amount": total, "by_project": by_project}


@app.post("/api/ata/{ata_id}/mark-invoiced")
async def mark_ata_invoiced(ata_id: int, request: Request, user: dict = Depends(get_current_user)):
    """Markera en ATA som fakturerad. Bodyfalt: invoice_number (required), invoice_amount (optional)."""

    require_perm(user, "ekonomi.invoices_all")
    data = await request.json()
    invoice_number = (data.get("invoice_number") or "").strip()
    if not invoice_number:
        raise HTTPException(status_code=400, detail="invoice_number kravs")
    invoice_amount = data.get("invoice_amount")
    safe_inv = invoice_number.replace("'", "''")
    invoiced_by = (user.get("name") or user.get("email") or "unknown").replace("'", "''")
    amt_clause = ""
    if invoice_amount is not None:
        try:
            amt_val = float(invoice_amount)
            amt_clause = f", invoice_amount = {amt_val}"
        except (TypeError, ValueError):
            pass
    result = run_psql(RM_CENTRAL_DB, f"""
        UPDATE ata_register
           SET invoice_number = '{safe_inv}',
               invoiced_at = NOW(),
               invoiced_by = '{invoiced_by}',
               status = 'invoiced',
               updated_at = NOW()
               {amt_clause}
         WHERE id = {ata_id}
         RETURNING ata_number, status, invoice_number, invoiced_at::text
    """)
    if not result:
        raise HTTPException(status_code=404, detail="ATA not found")
    return {"status": "invoiced", **result[0]}


@app.post("/api/ata/{ata_id}/unmark-invoiced")
async def unmark_ata_invoiced(ata_id: int, user: dict = Depends(get_current_user)):
    """Angra en felaktig fakturerad-markering."""

    require_perm(user, "ekonomi.invoices_all")
    # Smart status restore: approve->ordered, annars approved_internal
    result = run_psql(RM_CENTRAL_DB, f"""
        UPDATE ata_register
           SET invoiced_at = NULL, invoice_number = NULL, invoiced_by = NULL, invoice_amount = NULL,
               status = CASE WHEN customer_decision = 'approve' THEN 'ordered' ELSE 'approved_internal' END,
               updated_at = NOW()
         WHERE id = {ata_id}
         RETURNING ata_number
    """)
    if not result:
        raise HTTPException(status_code=404, detail="ATA not found")
    return {"status": "unmarked", "ata_number": result[0].get("ata_number")}


@app.get("/api/projects-raw")
async def get_projects_raw(request: Request, user: dict = Depends(get_current_user)):
    """Flat list of projects (one row per project_number), for /projekt index."""
    leader_filter = ""
    if not has_perm(user, "projects.read_all"):
        name = user["name"].replace("'", "''")
        leader_filter = f"AND project_leader ILIKE '%{name}%'"
    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT project_number, project_name, project_group, status, project_leader,
               net_revenue, supplier_costs, tb1, tb1_margin
        FROM project_profitability
        WHERE company_code='RM' {leader_filter}
        ORDER BY supplier_costs DESC NULLS LAST
    """)
    return {"count": len(rows), "projects": rows}





@app.get("/api/project-group/{group_name}/summary")
async def get_project_group_summary(group_name: str, user: dict = Depends(get_current_user)):
    """Return aggregated summary for a project group (e.g. 'Grimvägen' covering 2519+2521+2525)."""
    name = group_name.replace("'", "''")

    # Rollfilter: projektledare ser bara egna grupper
    leader_filter = ""
    if not has_perm(user, "projects.read_all"):
        pl = user["name"].replace("'", "''")
        leader_filter = f"AND project_leader ILIKE '%{pl}%'"

    # Alla projektnummer i gruppen (grupp = project_group ELLER project_name om group saknas)
    members = run_psql(RM_CENTRAL_DB, f"""
        SELECT project_number, project_name, project_group, status, project_leader,
               net_revenue, supplier_costs, tb1, tb1_margin,
               invoice_count, supplier_invoice_count, revenue, credit_notes,
               synced_at::text
        FROM project_profitability
        WHERE company_code='RM'
          AND COALESCE(NULLIF(project_group,''), project_name) = '{name}'
          {leader_filter}
        ORDER BY project_number
    """)

    if not members:
        return {
            "group_name": group_name,
            "members": [],
            "atas": [],
            "pdf_versions": [],
            "summary": {"member_count": 0, "net_revenue": 0, "supplier_costs": 0, "tb1": 0,
                        "ata_count": 0, "ata_estimated_total": 0, "ata_final_total": 0,
                        "pdf_version_count": 0, "pdf_bytes_total": 0},
        }

    codes = [m["project_number"] for m in members]
    codes_sql = ",".join(f"'{c}'" for c in codes)

    atas = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_number, project_code, project_name, description, status, category,
               estimated_amount, final_amount, reported_by, decided_by,
               customer_decision, created_at::text, updated_at::text
        FROM ata_register
        WHERE project_code IN ({codes_sql})
        ORDER BY created_at DESC
    """)

    versions = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_id, ata_number, project_code, version, filepath, file_size_bytes,
               stamped, state_at_generation, amount_at_generation,
               trigger_event, generated_by, generated_at::text
        FROM ata_document_version
        WHERE project_code IN ({codes_sql})
        ORDER BY generated_at DESC
        LIMIT 500
    """)

    summary = {
        "member_count": len(members),
        "net_revenue": sum(float(m.get("net_revenue") or 0) for m in members),
        "supplier_costs": sum(float(m.get("supplier_costs") or 0) for m in members),
        "tb1": sum(float(m.get("tb1") or 0) for m in members),
        "invoice_count": sum(int(m.get("invoice_count") or 0) for m in members),
        "supplier_invoice_count": sum(int(m.get("supplier_invoice_count") or 0) for m in members),
        "ata_count": len(atas),
        "ata_estimated_total": sum(float(a.get("estimated_amount") or 0) for a in atas),
        "ata_final_total": sum(float(a.get("final_amount") or 0) for a in atas),
        "ata_approved_count": sum(1 for a in atas if a.get("customer_decision") == "approved"),
        "pdf_version_count": len(versions),
        "pdf_bytes_total": sum(int(v.get("file_size_bytes") or 0) for v in versions),
    }

    return {
        "group_name": group_name,
        "members": members,
        "atas": atas,
        "pdf_versions": versions,
        "summary": summary,
    }



@app.get("/api/project/{project_code}/summary")
async def get_project_summary(project_code: str, user: dict = Depends(get_current_user)):
    """Return project info, ÄTA-list and PDF-archive versions for a single project."""
    code = project_code.replace("'", "''")

    # Projekt-metadata (en rad per project_number)
    prof_rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT project_number, project_name, project_group, status, project_leader,
               net_revenue, supplier_costs, tb1, tb1_margin,
               invoice_count, supplier_invoice_count, revenue, credit_notes,
               synced_at::text
        FROM project_profitability
        WHERE company_code='RM' AND project_number='{code}'
        LIMIT 1
    """)
    project = prof_rows[0] if prof_rows else None

    # ÄTA-rader
    atas = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_number, description, status, category,
               estimated_amount, final_amount,
               reported_by, decided_by, customer_approved, customer_decision,
               created_at::text, updated_at::text
        FROM ata_register
        WHERE project_code='{code}'
        ORDER BY created_at DESC
    """)

    # PDF-versioner
    versions = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, ata_id, ata_number, version, filepath, file_size_bytes,
               stamped, state_at_generation, amount_at_generation,
               trigger_event, generated_by, generated_at::text
        FROM ata_document_version
        WHERE project_code='{code}'
        ORDER BY generated_at DESC
        LIMIT 200
    """)

    # Summeringar
    summary = {
        "ata_count": len(atas),
        "ata_estimated_total": sum(float(a.get("estimated_amount") or 0) for a in atas),
        "ata_final_total": sum(float(a.get("final_amount") or 0) for a in atas),
        "ata_approved_count": sum(1 for a in atas if a.get("customer_decision") == "approved"),
        "pdf_version_count": len(versions),
        "pdf_bytes_total": sum(int(v.get("file_size_bytes") or 0) for v in versions),
    }

    return {
        "project_code": project_code,
        "project": project,
        "atas": atas,
        "pdf_versions": versions,
        "summary": summary,
    }



@app.get("/api/project-log")
async def list_project_log(
    user: dict = Depends(get_current_user),
    log_type: Optional[str] = None,
    project: Optional[str] = None,
    company: str = "RM"
):
    """List project log entries."""
    where = ["1=1"]
    if log_type:
        where.append(f"log_type='{log_type}'")
    if project:
        where.append(f"project_name ILIKE '%{project}%'")

    rows = run_psql(RM_CENTRAL_DB, f"""
        SELECT id, project_code, project_name, log_type, title, description,
               severity, reported_by, photo_urls::text, related_ata_id, tags::text, created_at::text
        FROM project_log
        WHERE {' AND '.join(where)}
        ORDER BY created_at DESC
        LIMIT 50
    """)
    return {"entries": rows, "count": len(rows)}




@app.get("/api/fortnox/payment-priority")
async def get_payment_priority(
    user: dict = Depends(get_current_user),
    company: str = "RM"
):
    """
    Kassaflodesstyrd betalningsprioritering.
    Matchar leverantorsfakturor mot kundfakturor per projekt.
    Fast kostnad -> BETALA, kund betalt -> BETALA, kund ej betalt -> PARKERA,
    kund forfallen -> ESKALERA, inget projekt -> MANUELL.
    """
    try:
        # 1. Unpaid supplier invoices
        sup_invs = run_psql(RM_CENTRAL_DB, f"""
            SELECT fortnox_id, supplier_name, invoice_date::text, due_date::text,
                   total::numeric(14,2), balance::numeric(14,2), project_code, label,
                   GREATEST(CURRENT_DATE - due_date, 0) as days_overdue
            FROM fortnox_supplier_invoice
            WHERE company_code='{company}' AND balance > 0 AND status != 'cancelled'
            ORDER BY due_date
        """)
        if not sup_invs:
            return {"summary": {"pay_count":0,"pay_total":0,"park_count":0,"park_total":0,
                    "escalate_count":0,"escalate_total":0,"manual_count":0,"manual_total":0}, "items": []}

        # 2. All customer invoices (for matching)
        cust_invs = run_psql(RM_CENTRAL_DB, f"""
            SELECT fortnox_id, customer_name, project_code, total::numeric(14,2),
                   balance::numeric(14,2), due_date::text,
                   CASE WHEN balance = 0 THEN true ELSE false END as is_paid
            FROM fortnox_invoice
            WHERE company_code='{company}' AND status != 'cancelled'
        """)

        # Index customer invoices by project
        cust_by_project = {}
        for ci in cust_invs:
            pc = str(ci.get("project_code") or "")
            if pc:
                cust_by_project.setdefault(pc, []).append(ci)

        # 3. Fixed costs (recurring, is_fixed=true)
        fixed_suppliers = run_psql(RM_CENTRAL_DB, f"""
            SELECT DISTINCT description FROM recurring_cost
            WHERE company_code='{company}' AND is_fixed = true AND active = true
        """)
        fixed_names = set()
        for r in fixed_suppliers:
            name = (r.get("description") or "").strip().lower()
            if name:
                fixed_names.add(name)

        # 4. Project names from next_project_economy
        proj_names_rows = run_psql(RM_CENTRAL_DB, """
            SELECT project_id::text, project_name FROM next_project_economy
        """)
        proj_name_map = {}
        for r in proj_names_rows:
            pid = r.get("project_id") or ""
            pname = r.get("project_name") or ""
            if pid:
                proj_name_map[str(pid)] = pname

        # 5. Process each supplier invoice
        items = []
        summary = {"pay_count":0, "pay_total":0, "park_count":0, "park_total":0,
                    "escalate_count":0, "escalate_total":0, "manual_count":0, "manual_total":0}

        for si in sup_invs:
            bal = float(si.get("balance") or 0)
            proj = str(si.get("project_code") or "")
            supplier = si.get("supplier_name") or ""
            days_over = int(si.get("days_overdue") or 0)

            action = "MANUELL"
            reason = "Saknar projektkoppling"
            customer_matches = []

            # Rule 1: Fixed cost
            is_fixed = supplier.strip().lower() in fixed_names
            if is_fixed:
                action = "BETALA"
                reason = "Fast kostnad - betalas alltid"
            # Find customer invoices: exact match first, then prefix match (e.g. 2081 -> 2081-1)
            elif proj:
                ci_list = cust_by_project.get(proj, [])
                if not ci_list:
                    # Prefix match: supplier code "2081" matches customer code "2081-1"
                    for cust_pc, cust_ci in cust_by_project.items():
                        if str(cust_pc).startswith(str(proj) + "-") or str(proj).startswith(str(cust_pc) + "-"):
                            ci_list.extend(cust_ci)
                if ci_list:
                    total_cust_invoiced = sum(float(c.get("total") or 0) for c in ci_list)
                    total_cust_paid = sum(float(c.get("total") or 0) - float(c.get("balance") or 0) for c in ci_list)
                    total_cust_unpaid = sum(float(c.get("balance") or 0) for c in ci_list)
                    any_cust_overdue = any(
                        (c.get("due_date") or "9999") < str(__import__('datetime').date.today()) and float(c.get("balance") or 0) > 0
                        for c in ci_list
                    )

                    customer_matches = [{
                        "fortnox_id": c.get("fortnox_id"),
                        "customer": c.get("customer_name"),
                        "total": float(c.get("total") or 0),
                        "balance": float(c.get("balance") or 0),
                        "paid": float(c.get("total") or 0) - float(c.get("balance") or 0),
                        "is_paid": c.get("is_paid") in (True, "true", "t")
                    } for c in ci_list]

                    if total_cust_unpaid == 0:
                        action = "BETALA"
                        reason = f"Kund betalt {int(total_cust_paid)} kr pa projekt {proj}"
                    elif any_cust_overdue:
                        action = "ESKALERA"
                        reason = f"Kundfaktura forfallen - {int(total_cust_unpaid)} kr obetalt"
                    else:
                        action = "PARKERA"
                        reason = f"Vantar pa kundbetalning - {int(total_cust_unpaid)} kr kvar"
                else:
                    action = "MANUELL"
                    reason = f"Projekt {proj} - ingen kundfaktura hittad"

            # Update summary
            if action == "BETALA":
                summary["pay_count"] += 1
                summary["pay_total"] += bal
            elif action == "PARKERA":
                summary["park_count"] += 1
                summary["park_total"] += bal
            elif action == "ESKALERA":
                summary["escalate_count"] += 1
                summary["escalate_total"] += bal
            else:
                summary["manual_count"] += 1
                summary["manual_total"] += bal

            items.append({
                "fortnox_id": si.get("fortnox_id"),
                "supplier_name": supplier,
                "total": float(si.get("total") or 0),
                "balance": bal,
                "due_date": si.get("due_date"),
                "invoice_date": si.get("invoice_date"),
                "days_overdue": days_over,
                "project_code": proj,
                "project_name": proj_name_map.get(proj, ""),
                "label": si.get("label") or "",
                "is_fixed_cost": is_fixed,
                "action": action,
                "reason": reason,
                "customer_invoices": customer_matches
            })

        # Sort: ESKALERA, BETALA, PARKERA, MANUELL
        order = {"ESKALERA": 0, "BETALA": 1, "PARKERA": 2, "MANUELL": 3}
        items.sort(key=lambda x: (order.get(x["action"], 4), -(x.get("balance") or 0)))

        # Round summary
        for k in ["pay_total", "park_total", "escalate_total", "manual_total"]:
            summary[k] = round(summary[k])

        return {"summary": summary, "items": items}

    except HTTPException:
        raise
    except Exception as e:
        import traceback; traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))

# ============================================================================
# Threshold & notification policies — konfigurerbara trösklar
# ============================================================================

class ThresholdPolicyCreate(BaseModel):
    scope_type: str
    scope_id: Optional[int] = None
    scope_value: Optional[str] = None
    metric_type: str
    green_at: float
    yellow_at: float
    window_weeks: int = 4
    min_data_points: int = 2
    at_risk_consecutive: int = 2
    direction: str = "higher_better"
    active: bool = True
    note: Optional[str] = None

class ThresholdPolicyUpdate(BaseModel):
    green_at: Optional[float] = None
    yellow_at: Optional[float] = None
    window_weeks: Optional[int] = None
    min_data_points: Optional[int] = None
    at_risk_consecutive: Optional[int] = None
    direction: Optional[str] = None
    active: Optional[bool] = None
    note: Optional[str] = None

@app.get("/api/threshold-policies")
async def list_threshold_policies(metric_type: Optional[str] = None, user: dict = Depends(get_current_user)):
    require_perm(user, "admin.threshold")
    where = ""
    params: list = []
    if metric_type:
        where = "WHERE metric_type=%s"
        params.append(metric_type)
    rows = query_dicts(
        f"""SELECT id, scope_type, scope_id, scope_value, metric_type,
                   green_at, yellow_at, window_weeks, min_data_points,
                   at_risk_consecutive, direction, active, note,
                   created_at, updated_at
            FROM threshold_policy {where}
            ORDER BY CASE scope_type WHEN 'target' THEN 1 WHEN 'role' THEN 2 WHEN 'company' THEN 3 WHEN 'system' THEN 4 END,
                     metric_type, id""",
        params
    )
    return {"policies": rows}

@app.post("/api/threshold-policies")
async def create_threshold_policy(body: ThresholdPolicyCreate, user: dict = Depends(get_current_user)):
    require_perm(user, "admin.threshold")
    new_id = execute(
        """INSERT INTO threshold_policy
           (scope_type, scope_id, scope_value, metric_type, green_at, yellow_at,
            window_weeks, min_data_points, at_risk_consecutive, direction, active, note)
           VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s) RETURNING id""",
        [body.scope_type, body.scope_id, body.scope_value, body.metric_type,
         body.green_at, body.yellow_at, body.window_weeks, body.min_data_points,
         body.at_risk_consecutive, body.direction, body.active, body.note],
        returning=True
    )
    return {"ok": True, "id": new_id}

@app.put("/api/threshold-policies/{policy_id}")
async def update_threshold_policy(policy_id: int, body: ThresholdPolicyUpdate, user: dict = Depends(get_current_user)):
    require_perm(user, "admin.threshold")
    sent = body.model_fields_set if hasattr(body, "model_fields_set") else set()
    sets: list = []
    params: list = []
    for field in ["green_at","yellow_at","window_weeks","min_data_points","at_risk_consecutive","direction","active","note"]:
        if field in sent:
            sets.append(f"{field}=%s")
            params.append(getattr(body, field))
    if not sets:
        return {"ok": True, "updated": 0}
    sets.append("updated_at=now()")
    params.append(policy_id)
    execute(f"UPDATE threshold_policy SET {', '.join(sets)} WHERE id=%s", params)
    return {"ok": True, "id": policy_id}

@app.delete("/api/threshold-policies/{policy_id}")
async def delete_threshold_policy(policy_id: int, user: dict = Depends(get_current_user)):
    require_perm(user, "admin.threshold")
    # Skydda system-defaults
    scope = query_one("SELECT scope_type FROM threshold_policy WHERE id=%s", [policy_id])
    if not scope:
        raise HTTPException(status_code=404, detail="not found")
    if scope == "system":
        raise HTTPException(status_code=400, detail="Kan inte ta bort system-default. Avaktivera istället.")
    execute("DELETE FROM threshold_policy WHERE id=%s", [policy_id])
    return {"ok": True}

@app.get("/api/threshold-policies/resolve")
async def resolve_threshold(
    metric_type: str,
    target_id: Optional[int] = None,
    role: Optional[str] = None,
    company: Optional[str] = None,
    user: dict = Depends(get_current_user)
):
    res = query_dicts(
        "SELECT * FROM get_threshold(%s, %s, %s, %s)",
        [target_id, role, company, metric_type]
    )
    if not res:
        raise HTTPException(status_code=404, detail="no threshold resolved")
    return res[0]

class NotificationPolicyCreate(BaseModel):
    scope_type: str
    scope_id: Optional[int] = None
    scope_value: Optional[str] = None
