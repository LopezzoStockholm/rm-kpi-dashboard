@app.post("/api/scorecard/target")
async def create_target(target: TargetCreate):
    """Skapa ny scorecard-target."""
    new_id = execute(
        """INSERT INTO scorecard_target (company_code, metric_name, role, target_value, unit, frequency, owner, is_green_above, sort_order, active, key_activity_id, source_query, auto_populate)
           VALUES ('RM', %s, %s, %s, %s, %s, %s, %s, %s, true, %s, %s, %s) RETURNING id""",
        (target.metric_name, target.role, target.target_value, target.unit, target.frequency, target.owner, target.is_green_above, target.sort_order, target.key_activity_id, target.source_query, target.auto_populate),
        returning=True
    )
    if new_id is None:
        raise HTTPException(status_code=500, detail="Kunde inte skapa target")
    return {"id": new_id}


@app.put("/api/scorecard/target/{target_id}")
async def update_target(target_id: int, update: TargetUpdate):
    """Uppdatera scorecard-target."""
    sets = []
    params = []
    sent = update.model_fields_set if hasattr(update, "model_fields_set") else set()
    for field in ["metric_name", "role", "target_value", "unit", "frequency", "owner", "is_green_above", "sort_order", "active", "key_activity_id", "source_query", "auto_populate"]:
        if field in sent:
            sets.append(f"{field}=%s")
            params.append(getattr(update, field))
    if not sets:
        raise HTTPException(status_code=400, detail="Inget att uppdatera")
    params.append(target_id)
    execute(f"UPDATE scorecard_target SET {', '.join(sets)} WHERE id=%s", params)
    return {"ok": True, "id": target_id}


@app.delete("/api/scorecard/target/{target_id}")
async def delete_target(target_id: int):
    """Soft delete: sätt active=false."""
    execute("UPDATE scorecard_target SET active=false WHERE id=%s", (target_id,))
    return {"ok": True, "id": target_id}


