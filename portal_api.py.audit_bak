# ============================================================================
# In-app notifications (dashboard_only-kanalen)
# ============================================================================

def _user_identity(user: dict) -> str:
    """Returnerar den identifierare som dashboard_notification.owner använder."""
    return (user.get("planner_email") or user.get("email")
            or user.get("username") or "")


@app.get("/api/notifications")
async def list_notifications(user: dict = Depends(get_current_user),
                             unread_only: bool = False, limit: int = 50):
    ident = _user_identity(user)
    if not ident:
        return {"notifications": [], "unread_count": 0}
    where = "WHERE owner = %s"
    params = [ident]
    if unread_only:
        where += " AND read_at IS NULL"
    rows = query_dicts(f"""
        SELECT id, trigger_event, title, body, link, severity,
               read_at, created_at
        FROM dashboard_notification
        {where}
        ORDER BY created_at DESC
        LIMIT %s
    """, params + [limit])
    unread = query_one("""
        SELECT count(*) FROM dashboard_notification
        WHERE owner = %s AND read_at IS NULL
    """, [ident]) or 0
    return {"notifications": rows, "unread_count": unread}


@app.post("/api/notifications/{notif_id}/read")
async def mark_notification_read(notif_id: int,
                                 user: dict = Depends(get_current_user)):
    ident = _user_identity(user)
    execute("""
        UPDATE dashboard_notification
        SET read_at = now()
        WHERE id = %s AND owner = %s AND read_at IS NULL
    """, (notif_id, ident))
    return {"ok": True}


@app.post("/api/notifications/read-all")
async def mark_all_read(user: dict = Depends(get_current_user)):
    ident = _user_identity(user)
    execute("""
        UPDATE dashboard_notification
        SET read_at = now()
        WHERE owner = %s AND read_at IS NULL
    """, [ident])
    return {"ok": True}


@app.delete("/api/notifications/{notif_id}")
async def delete_notification(notif_id: int,
                              user: dict = Depends(get_current_user)):
    ident = _user_identity(user)
    execute("""
        DELETE FROM dashboard_notification
        WHERE id = %s AND owner = %s
    """, (notif_id, ident))
    return {"ok": True}


@app.post("/api/notifications/test")
async def test_notification(body: dict, user: dict = Depends(get_current_user)):
    """VD-only: skicka en test-notis via en specifik policy (bypass cooldown/quiet)."""
    require_perm(user, "admin.notifications")
    policy_id = body.get("policy_id")
    if not policy_id:
        raise HTTPException(status_code=400, detail="policy_id krävs")
    pol_rows = query_dicts(
        "SELECT * FROM notification_policy WHERE id=%s", [policy_id])
    if not pol_rows:
        raise HTTPException(status_code=404, detail="Policy hittades ej")
    policy = pol_rows[0]
    ident = _user_identity(user)
    title = f"TEST: {policy['trigger_event']}"
    template = policy.get('message_template') or 'Test-notis'
    body_text = template.replace('{activity_name}', 'Test-aktivitet')\
        .replace('{hit_pct}', '42').replace('{window_weeks}', '4')\
        .replace('{consecutive_red}', '2').replace('{threshold_green}', '80')\
        .replace('{threshold_yellow}', '50').replace('{consecutive}', '2')\
        .replace('{window}', '4').replace('{owner}', ident)\
        .replace('{target_name}', 'Test-mål').replace('{actual}', '5')\
        .replace('{target}', '10').replace('{blocker_text}', 'Test-blocker')\
        .replace('{link}', '/admin/hit-rate')
    new_id = execute("""
        INSERT INTO dashboard_notification
          (owner, trigger_event, title, body, link, severity)
        VALUES (%s, %s, %s, %s, %s, 'info')
    """, (ident, policy['trigger_event'], title, body_text, '/admin/hit-rate'),
        returning=True)
    return {"ok": True, "id": new_id}

# ============================================================================
# Notification admin-endpoints (VD-only log + queue + stats)
# ============================================================================

@app.get("/api/notifications/log")
async def notifications_log(user: dict = Depends(get_current_user),
                            days: int = 7, status: str = None,
                            owner: str = None, channel: str = None,
                            limit: int = 200):
    require_perm(user, "admin.notifications")
    where = ["sent_at >= now() - (%s || ' days')::interval"]
    params = [days]
    if status:
        where.append("status = %s")
        params.append(status)
    if owner:
        where.append("owner ILIKE %s")
        params.append(f"%{owner}%")
    if channel:
        where.append("channel = %s")
        params.append(channel)
    rows = query_dicts(f"""
        SELECT l.id, l.nudge_id, l.owner, l.trigger_event, l.channel,
               l.recipient, l.rendered_message, l.policy_id, l.status,
               l.channel_message_id, l.error_message, l.sent_at,
               p.scope_type AS policy_scope, p.scope_value AS policy_scope_value
        FROM notification_log l
        LEFT JOIN notification_policy p ON p.id = l.policy_id
        WHERE {' AND '.join(where)}
        ORDER BY l.sent_at DESC
        LIMIT %s
    """, params + [limit])
    return {"log": rows, "count": len(rows)}


@app.get("/api/notifications/queue")
async def notifications_queue(user: dict = Depends(get_current_user),
                              status: str = None, limit: int = 200):
    require_perm(user, "admin.notifications")
    where = []
    params = []
    if status:
        where.append("status = %s")
        params.append(status)
    wclause = "WHERE " + " AND ".join(where) if where else ""
    rows = query_dicts(f"""
        SELECT n.id, n.owner, n.nudge_type, n.iso_week, n.status,
               n.channel, n.attempts, n.last_attempt_at, n.error_message,
               n.scheduled_at, n.sent_at, n.created_at,
               k.title AS activity_name
        FROM nudge_queue n
        LEFT JOIN key_activity k ON k.id = n.key_activity_id
        {wclause}
        ORDER BY
          CASE n.status
            WHEN 'failed' THEN 1
            WHEN 'retrying' THEN 2
            WHEN 'pending' THEN 3
            ELSE 9
          END,
          COALESCE(n.scheduled_at, n.created_at) DESC
        LIMIT %s
    """, params + [limit])
    return {"queue": rows, "count": len(rows)}


@app.get("/api/notifications/stats")
async def notifications_stats(user: dict = Depends(get_current_user),
                              days: int = 7):
    require_perm(user, "admin.notifications")
    by_status = query_dicts("""
        SELECT status, count(*) AS n
        FROM notification_log
        WHERE sent_at >= now() - (%s || ' days')::interval
        GROUP BY status ORDER BY n DESC
    """, [days])
    by_channel = query_dicts("""
        SELECT channel, count(*) AS n
        FROM notification_log
        WHERE sent_at >= now() - (%s || ' days')::interval AND status='sent'
        GROUP BY channel ORDER BY n DESC
    """, [days])
    by_trigger = query_dicts("""
        SELECT trigger_event, count(*) AS n
        FROM notification_log
        WHERE sent_at >= now() - (%s || ' days')::interval AND status='sent'
        GROUP BY trigger_event ORDER BY n DESC
    """, [days])
    by_owner = query_dicts("""
        SELECT owner, count(*) AS n
        FROM notification_log
        WHERE sent_at >= now() - (%s || ' days')::interval AND status='sent'
        GROUP BY owner ORDER BY n DESC
    """, [days])
    queue_summary = query_dicts("""
        SELECT status, count(*) AS n FROM nudge_queue
        GROUP BY status ORDER BY n DESC
    """)
    return {
        "by_status": by_status,
        "by_channel": by_channel,
        "by_trigger": by_trigger,
        "by_owner": by_owner,
        "queue_summary": queue_summary,
        "days": days,
    }


@app.post("/api/notifications/retry/{nudge_id}")
async def retry_nudge(nudge_id: int, user: dict = Depends(get_current_user)):
    """VD-only: återställ failed-nudge till pending för ny leverans."""
    require_perm(user, "admin.notifications")
    execute("""
        UPDATE nudge_queue
        SET status='pending', attempts=0, error_message=NULL,
            scheduled_at=now(), last_attempt_at=NULL
        WHERE id=%s
    """, (nudge_id,))
    return {"ok": True}


@app.post("/api/notifications/reset-cooldown")
async def reset_cooldown(body: dict, user: dict = Depends(get_current_user)):
    """VD-only: rensa notification_log så cooldown förbigås för viss owner/trigger."""
    require_perm(user, "admin.notifications")
    owner = body.get("owner")
    trigger = body.get("trigger_event")
    if not owner:
        raise HTTPException(status_code=400, detail="owner krävs")
    if trigger:
        execute("""
            DELETE FROM notification_log
            WHERE owner=%s AND trigger_event=%s
              AND sent_at >= now() - interval '30 days'
        """, (owner, trigger))
    else:
        execute("""
            DELETE FROM notification_log
            WHERE owner=%s AND sent_at >= now() - interval '30 days'
        """, (owner,))
    return {"ok": True}
# ============================================================================
# Task Hub — CRUD API endpoints
# Appenderas till portal_api.py
# ============================================================================

from uuid import UUID as _UUID

# --- Pydantic models for Task Hub ---

class TaskHubCreate(BaseModel):
    title: str
    description: Optional[str] = None
    task_type: str = "action"
    context: Optional[str] = None
    priority: int = 2
    assignee_name: Optional[str] = None
    assignee_email: Optional[str] = None
    project_code: Optional[str] = None
    project_name: Optional[str] = None
    deal_id: Optional[str] = None
    ata_id: Optional[int] = None
    parent_task_id: Optional[str] = None
    board_column: str = "inbox"
    due_date: Optional[str] = None
    source: str = "manual"
    company_id: Optional[str] = None
    company_name: Optional[str] = None
    contact_name: Optional[str] = None

class TaskHubUpdate(BaseModel):
    title: Optional[str] = None
    description: Optional[str] = None
    task_type: Optional[str] = None
    context: Optional[str] = None
    priority: Optional[int] = None
    assignee_name: Optional[str] = None
    assignee_email: Optional[str] = None
    project_code: Optional[str] = None
    project_name: Optional[str] = None
    deal_id: Optional[str] = None
    ata_id: Optional[int] = None
    parent_task_id: Optional[str] = None
    board_column: Optional[str] = None
    due_date: Optional[str] = None
    company_id: Optional[str] = None
    company_name: Optional[str] = None
    contact_name: Optional[str] = None

class TaskHubMove(BaseModel):
    board_column: str
    sort_order: int = 0

class TaskHubStatusChange(BaseModel):
    status: str  # open, done, wontdo

class TaskHubSnooze(BaseModel):
    snooze_until: str  # ISO datetime

class BlockerCreate(BaseModel):
    blocker_type: str  # waiting_person, waiting_approval, waiting_material, waiting_document, blocking_task, external
    blocking_task_id: Optional[str] = None
    waiting_for_name: Optional[str] = None
    waiting_for_email: Optional[str] = None
    waiting_for_org: Optional[str] = None
    follow_up_date: Optional[str] = None
    note: Optional[str] = None

class BlockerResolve(BaseModel):
    resolution_note: Optional[str] = None

class BlockerFollowUp(BaseModel):
    note: Optional[str] = None
    next_follow_up_date: Optional[str] = None


# --- Helper: log activity ---

def _log_task_activity(task_id: str, action: str, field: str = None,
                       old_value: str = None, new_value: str = None,
                       actor: str = None):
    execute(
        """INSERT INTO task_activity (task_id, action, field, old_value, new_value, actor)
           VALUES (%s, %s, %s, %s, %s, %s)""",
        (task_id, action, field, old_value, new_value, actor)
    )


# --- Helper: SQL-safe string ---

def _sq(val):
    """Escape single quotes for SQL interpolation in run_psql."""
    if val is None:
        return None
    return str(val).replace("'", "''")


# ============================================================================
# Task CRUD
# ============================================================================

@app.get("/api/hub/tasks")
async def hub_list_tasks(
    request: Request,
    user: dict = Depends(get_current_user),
    status: Optional[str] = None,
    assignee: Optional[str] = None,
    project: Optional[str] = None,
    context: Optional[str] = None,
    task_type: Optional[str] = None,
    board_column: Optional[str] = None,
    parent_id: Optional[str] = None,
    search: Optional[str] = None,
    limit: int = 200,
    offset: int = 0,
):
    """Lista tasks med filter. VD ser alla, andra ser bara sina."""
    try:
        conditions = ["t.status != 'wontdo'"]

        if status:
            conditions.append(f"t.status = '{_sq(status)}'")
        if context:
            conditions.append(f"t.context = '{_sq(context)}'")
        if task_type:
            conditions.append(f"t.task_type = '{_sq(task_type)}'")
        if board_column:
            conditions.append(f"t.board_column = '{_sq(board_column)}'")
        if project:
            conditions.append(f"t.project_code = '{_sq(project)}'")
        if parent_id:
            conditions.append(f"t.parent_task_id = '{_sq(parent_id)}'")
        if search:
            conditions.append(f"t.title ILIKE '%{_sq(search)}%'")

        # Assignee filter
        if assignee:
            conditions.append(f"t.assignee_email = '{_sq(assignee)}'")
        elif not has_perm(user, "tasks.read_all"):
            email = user.get("email")
            if email:
                conditions.append(f"(t.assignee_email = '{_sq(email)}' OR t.assignee_email IS NULL)")

        where = " AND ".join(conditions)

        query = f"""
            SELECT t.*,
                   (SELECT COUNT(*) FROM task_blocker b
                    WHERE b.task_id = t.id AND b.status = 'active') as active_blockers,
                   (SELECT COUNT(*) FROM rm_task sub
                    WHERE sub.parent_task_id = t.id AND sub.status != 'wontdo') as subtask_count,
                   (SELECT COUNT(*) FROM rm_task sub
                    WHERE sub.parent_task_id = t.id AND sub.status = 'done') as subtask_done
            FROM rm_task t
            WHERE {where}
            ORDER BY t.board_column, t.sort_order, t.priority, t.due_date NULLS LAST
            LIMIT {limit} OFFSET {offset}
        """

        tasks = run_psql(RM_CENTRAL_DB, query)
        count_q = f"SELECT COUNT(*) as cnt FROM rm_task t WHERE {where}"
        total = run_psql(RM_CENTRAL_DB, count_q)
        total_count = total[0]["cnt"] if total else 0

        return {"ok": True, "count": len(tasks), "total": total_count, "tasks": tasks}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/tasks/board")
async def hub_board_view(user: dict = Depends(get_current_user)):
    """Kanban-vy: tasks grupperade per board_column."""
    try:
        # Hämta konfigurerade kolumner
        columns = run_psql(RM_CENTRAL_DB, """
            SELECT column_key, display_name, icon, wip_limit, sort_order
            FROM board_column_config
            WHERE company_code = 'RM' AND active = true
            ORDER BY sort_order
        """)

        # Hämta tasks (VD ser alla)
        assignee_filter = ""
        if not has_perm(user, "tasks.read_all"):
            email = user.get("email")
            if email:
                assignee_filter = f"AND (t.assignee_email = '{_sq(email)}' OR t.assignee_email IS NULL)"

        tasks = run_psql(RM_CENTRAL_DB, f"""
            SELECT t.*,
                   COALESCE(t.project_name, pu.project_name) as project_name,
                   (SELECT COUNT(*) FROM task_blocker b
                    WHERE b.task_id = t.id AND b.status = 'active') as active_blockers,
                   (SELECT COUNT(*) FROM task_blocker b
                    WHERE b.task_id = t.id AND b.status = 'active' AND b.escalated = true) as escalated_blockers
            FROM rm_task t
            LEFT JOIN project_unified pu ON pu.project_number = t.project_code
            WHERE t.status != 'wontdo' {assignee_filter}
            ORDER BY t.sort_order, t.priority, t.due_date NULLS LAST
        """)

        # Gruppera per kolumn
        board = {}
        for col in columns:
            key = col["column_key"]
            board[key] = {
                "column": col,
                "tasks": [t for t in tasks if t.get("board_column") == key]
            }

        return {"ok": True, "board": board, "columns": columns}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/tasks/today")
async def hub_today_view(user: dict = Depends(get_current_user)):
    """Today-vy: due_date <= idag ELLER snooze_until <= now ELLER board_column = today."""
    try:
        assignee_filter = ""
        if not has_perm(user, "tasks.read_all"):
            email = user.get("email")
            if email:
                assignee_filter = f"AND (t.assignee_email = '{_sq(email)}' OR t.assignee_email IS NULL)"

        tasks = run_psql(RM_CENTRAL_DB, f"""
            SELECT t.*,
                   COALESCE(t.project_name, pu.project_name) as project_name,
                   (SELECT COUNT(*) FROM task_blocker b
                    WHERE b.task_id = t.id AND b.status = 'active') as active_blockers
            FROM rm_task t
            LEFT JOIN project_unified pu ON pu.project_number = t.project_code
            WHERE t.status NOT IN ('done', 'wontdo')
              AND (
                t.board_column = 'today'
                OR t.due_date <= CURRENT_DATE
                OR (t.snooze_until IS NOT NULL AND t.snooze_until <= NOW())
              )
              {assignee_filter}
            ORDER BY t.priority, t.due_date NULLS LAST
        """)

        return {"ok": True, "count": len(tasks), "tasks": tasks}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/tasks/waiting")
async def hub_waiting_view(user: dict = Depends(get_current_user)):
    """Alla tasks med aktiva blockers + blocker-detaljer."""
    try:
        assignee_filter = ""
        if not has_perm(user, "tasks.read_all"):
            email = user.get("email")
            if email:
                assignee_filter = f"AND (t.assignee_email = '{_sq(email)}' OR t.assignee_email IS NULL)"

        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT t.id as task_id, t.title as task_title, t.project_code,
                   COALESCE(t.project_name, pu.project_name) as project_name,
                   t.priority, t.due_date,
                   b.id as blocker_id, b.blocker_type, b.waiting_for_name, b.waiting_for_email,
                   b.waiting_for_org, b.waiting_since, b.follow_up_date, b.follow_up_count,
                   b.last_follow_up_at, b.reminder_sent, b.escalated, b.note,
                   EXTRACT(EPOCH FROM (NOW() - b.waiting_since)) / 86400 as days_waiting
            FROM rm_task t
            LEFT JOIN project_unified pu ON pu.project_number = t.project_code
            JOIN task_blocker b ON b.task_id = t.id AND b.status = 'active'
            WHERE t.status NOT IN ('done', 'wontdo')
              {assignee_filter}
            ORDER BY b.follow_up_date NULLS LAST, b.waiting_since
        """)

        return {"ok": True, "count": len(rows), "items": rows}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/tasks/overdue")
async def hub_overdue_view(user: dict = Depends(get_current_user)):
    """Tasks med due_date < idag som inte är klara."""
    try:
        assignee_filter = ""
        if not has_perm(user, "tasks.read_all"):
            email = user.get("email")
            if email:
                assignee_filter = f"AND (t.assignee_email = '{_sq(email)}' OR t.assignee_email IS NULL)"

        tasks = run_psql(RM_CENTRAL_DB, f"""
            SELECT t.*,
                   COALESCE(t.project_name, pu.project_name) as project_name,
                   (CURRENT_DATE - t.due_date) as days_overdue
            FROM rm_task t
            LEFT JOIN project_unified pu ON pu.project_number = t.project_code
            WHERE t.status NOT IN ('done', 'wontdo')
              AND t.due_date < CURRENT_DATE
              {assignee_filter}
            ORDER BY t.due_date ASC
        """)

        return {"ok": True, "count": len(tasks), "tasks": tasks}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/tasks/{task_id}")
async def hub_get_task(task_id: str, user: dict = Depends(get_current_user)):
    """Hämta en task med blockers, activity och subtasks."""
    try:
        task = run_psql(RM_CENTRAL_DB, f"""
            SELECT t.*, COALESCE(t.project_name, pu.project_name) as project_name
            FROM rm_task t
            LEFT JOIN project_unified pu ON pu.project_number = t.project_code
            WHERE t.id = '{_sq(task_id)}'
        """)
        if not task:
            raise HTTPException(status_code=404, detail="Task finns inte")

        blockers = run_psql(RM_CENTRAL_DB, f"""
            SELECT * FROM task_blocker
            WHERE task_id = '{_sq(task_id)}'
            ORDER BY status DESC, created_at DESC
        """)

        activity = run_psql(RM_CENTRAL_DB, f"""
            SELECT * FROM task_activity
            WHERE task_id = '{_sq(task_id)}'
            ORDER BY created_at DESC
            LIMIT 50
        """)

        subtasks = run_psql(RM_CENTRAL_DB, f"""
            SELECT id, title, status, board_column, priority, due_date, assignee_name
            FROM rm_task
            WHERE parent_task_id = '{_sq(task_id)}' AND status != 'wontdo'
            ORDER BY sort_order, priority
        """)

        return {
            "ok": True,
            "task": task[0],
            "blockers": blockers,
            "activity": activity,
            "subtasks": subtasks
        }
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/api/hub/tasks")
async def hub_create_task(body: TaskHubCreate, user: dict = Depends(get_current_user)):
    """Skapa ny task i rm_task."""
    try:
        # Default assignee till inloggad användare om ej angivet
        assignee_email = body.assignee_email or user.get("email")
        assignee_name = body.assignee_name or user.get("name")

        # Auto-routing: om tilldelad till annan person → waiting
        user_email = user.get("email", "")
        board_column = body.board_column  # default "inbox"
        if assignee_email and assignee_email != user_email:
            board_column = "waiting"

        new_id = execute(
            """INSERT INTO rm_task
               (company_code, title, description, task_type, context, priority,
                assignee_name, assignee_email, created_by,
                project_code, project_name, deal_id, ata_id, parent_task_id,
                board_column, due_date, source,
                company_id, company_name, contact_name)
               VALUES ('RM', %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s::uuid, %s, %s)
               RETURNING id""",
            (
                body.title, body.description, body.task_type, body.context, body.priority,
                assignee_name, assignee_email, user.get("email") or user.get("name"),
                body.project_code, body.project_name,
                body.deal_id, body.ata_id, body.parent_task_id,
                board_column, body.due_date, body.source,
                body.company_id or None, body.company_name, body.contact_name
            ),
            returning=True
        )

        if new_id is None:
            raise HTTPException(status_code=500, detail="Kunde inte skapa task")

        # Logga skapande
        _log_task_activity(str(new_id), "created", actor=user.get("name"))

        # Hämta tillbaka den skapade tasken
        task = run_psql(RM_CENTRAL_DB, f"SELECT * FROM rm_task WHERE id = '{new_id}'")

        return {"ok": True, "id": str(new_id), "task": task[0] if task else None}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.put("/api/hub/tasks/{task_id}")
async def hub_update_task(task_id: str, body: TaskHubUpdate, user: dict = Depends(get_current_user)):
    """Uppdatera valfria fält på en task."""
    try:
        # Hämta nuvarande värden för activity-logg
        current = run_psql(RM_CENTRAL_DB, f"SELECT * FROM rm_task WHERE id = '{_sq(task_id)}'")
        if not current:
            raise HTTPException(status_code=404, detail="Task finns inte")

        sets = []
        params = []
        updatable = [
            "title", "description", "task_type", "context", "priority",
            "assignee_name", "assignee_email", "project_code", "project_name",
            "deal_id", "ata_id", "parent_task_id", "board_column", "due_date"
        ]

        for field in updatable:
            val = getattr(body, field, None)
            if val is not None:
                sets.append(f"{field}=%s")
                params.append(val)
                # Logga ändring
                old_val = current[0].get(field)
                if str(old_val) != str(val):
                    _log_task_activity(task_id, "updated", field=field,
                                       old_value=str(old_val), new_value=str(val),
                                       actor=user.get("name"))

        if not sets:
            raise HTTPException(status_code=400, detail="Inget att uppdatera")

        # Auto-routing: om assignee ändras, justera board_column
        new_assignee = getattr(body, 'assignee_email', None)
        if new_assignee is not None:
            user_email = user.get("email", "")
            current_col = current[0].get("board_column", "inbox")
            if new_assignee != user_email and current_col in ("inbox", "today"):
                # Delegerad till annan → waiting
                sets.append("board_column=%s")
                params.insert(-1, "waiting")
            elif new_assignee == user_email and current_col == "waiting":
                # Tillbaka till mig → inbox
                sets.append("board_column=%s")
                params.insert(-1, "inbox")

        sets.append("updated_at=NOW()")
        params.append(task_id)

        execute(f"UPDATE rm_task SET {', '.join(sets)} WHERE id=%s", params)

        task = run_psql(RM_CENTRAL_DB, f"SELECT * FROM rm_task WHERE id = '{_sq(task_id)}'")
        return {"ok": True, "task": task[0] if task else None}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/tasks/{task_id}/status")
async def hub_change_status(task_id: str, body: TaskHubStatusChange, user: dict = Depends(get_current_user)):
    """Byt status. done → sätter completed_at. Triggar connector-synk i framtiden."""
    try:
        current = run_psql(RM_CENTRAL_DB, f"SELECT status, external_system, external_id FROM rm_task WHERE id = '{_sq(task_id)}'")
        if not current:
            raise HTTPException(status_code=404, detail="Task finns inte")

        old_status = current[0]["status"]
        new_status = body.status

        if new_status == "done":
            execute(
                "UPDATE rm_task SET status=%s, completed_at=NOW(), updated_at=NOW(), board_column='done' WHERE id=%s",
                (new_status, task_id)
            )
        elif new_status == "open":
            execute(
                "UPDATE rm_task SET status=%s, completed_at=NULL, updated_at=NOW() WHERE id=%s",
                (new_status, task_id)
            )
        else:
            execute(
                "UPDATE rm_task SET status=%s, updated_at=NOW() WHERE id=%s",
                (new_status, task_id)
            )

        _log_task_activity(task_id, "status_changed", field="status",
                           old_value=old_status, new_value=new_status,
                           actor=user.get("name"))

        # TODO: Connector-synk (Fas 3+4)
        # ext_system = current[0].get("external_system")
        # ext_id = current[0].get("external_id")
        # if ext_system == "planner" and ext_id:
        #     sync_to_planner(ext_id, new_status)
        # elif ext_system == "twenty" and ext_id:
        #     sync_to_twenty(ext_id, new_status)

        return {"ok": True, "old_status": old_status, "new_status": new_status}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/tasks/{task_id}/move")
async def hub_move_task(task_id: str, body: TaskHubMove, user: dict = Depends(get_current_user)):
    """Flytta task till annan kolumn (drag-drop)."""
    try:
        current = run_psql(RM_CENTRAL_DB, f"SELECT board_column FROM rm_task WHERE id = '{_sq(task_id)}'")
        if not current:
            raise HTTPException(status_code=404, detail="Task finns inte")

        old_col = current[0]["board_column"]

        execute(
            "UPDATE rm_task SET board_column=%s, sort_order=%s, updated_at=NOW() WHERE id=%s",
            (body.board_column, body.sort_order, task_id)
        )

        if old_col != body.board_column:
            _log_task_activity(task_id, "moved", field="board_column",
                               old_value=old_col, new_value=body.board_column,
                               actor=user.get("name"))

        return {"ok": True, "board_column": body.board_column, "sort_order": body.sort_order}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/tasks/{task_id}/snooze")
async def hub_snooze_task(task_id: str, body: TaskHubSnooze, user: dict = Depends(get_current_user)):
    """Snooze task till visst datum/tid."""
    try:
        execute(
            "UPDATE rm_task SET snooze_until=%s, updated_at=NOW() WHERE id=%s",
            (body.snooze_until, task_id)
        )

        _log_task_activity(task_id, "snoozed", field="snooze_until",
                           new_value=body.snooze_until, actor=user.get("name"))

        return {"ok": True, "snooze_until": body.snooze_until}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.delete("/api/hub/tasks/{task_id}")
async def hub_delete_task(task_id: str, user: dict = Depends(get_current_user)):
    """Soft delete — sätter status = wontdo."""
    try:
        execute(
            "UPDATE rm_task SET status='wontdo', updated_at=NOW() WHERE id=%s",
            (task_id,)
        )

        _log_task_activity(task_id, "status_changed", field="status",
                           new_value="wontdo", actor=user.get("name"))

        return {"ok": True}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


# ============================================================================
# Blockers / Waiting-for
# ============================================================================

@app.get("/api/hub/tasks/{task_id}/blockers")
async def hub_list_blockers(task_id: str, user: dict = Depends(get_current_user)):
    """Lista blockers för en task."""
    try:
        blockers = run_psql(RM_CENTRAL_DB, f"""
            SELECT *,
                   EXTRACT(EPOCH FROM (NOW() - waiting_since)) / 86400 as days_waiting
            FROM task_blocker
            WHERE task_id = '{_sq(task_id)}'
            ORDER BY status DESC, created_at DESC
        """)
        return {"ok": True, "blockers": blockers}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/api/hub/tasks/{task_id}/blockers")
async def hub_create_blocker(task_id: str, body: BlockerCreate, user: dict = Depends(get_current_user)):
    """Lägg till blocker. Sätter task board_column = waiting om aktiv."""
    try:
        # Verifiera att task finns
        task = run_psql(RM_CENTRAL_DB, f"SELECT id FROM rm_task WHERE id = '{_sq(task_id)}'")
        if not task:
            raise HTTPException(status_code=404, detail="Task finns inte")

        new_id = execute(
            """INSERT INTO task_blocker
               (task_id, blocker_type, blocking_task_id,
                waiting_for_name, waiting_for_email, waiting_for_org,
                follow_up_date, note)
               VALUES (%s, %s, %s, %s, %s, %s, %s, %s)
               RETURNING id""",
            (
                task_id, body.blocker_type, body.blocking_task_id,
                body.waiting_for_name, body.waiting_for_email, body.waiting_for_org,
                body.follow_up_date, body.note
            ),
            returning=True
        )

        # Flytta task till waiting-kolumnen
        execute(
            "UPDATE rm_task SET board_column='waiting', updated_at=NOW() WHERE id=%s",
            (task_id,)
        )

        _log_task_activity(task_id, "blocker_added",
                           new_value=f"{body.blocker_type}: {body.waiting_for_name or body.waiting_for_org or ''}",
                           actor=user.get("name"))

        return {"ok": True, "blocker_id": str(new_id)}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/blockers/{blocker_id}/resolve")
async def hub_resolve_blocker(blocker_id: str, body: BlockerResolve, user: dict = Depends(get_current_user)):
    """Lös en blocker. Om sista aktiva → flytta task tillbaka till inbox/planned."""
    try:
        # Hämta blocker + task_id
        blocker = run_psql(RM_CENTRAL_DB, f"""
            SELECT task_id FROM task_blocker WHERE id = '{_sq(blocker_id)}' AND status = 'active'
        """)
        if not blocker:
            raise HTTPException(status_code=404, detail="Blocker finns inte eller redan löst")

        task_id = blocker[0]["task_id"]

        # Markera blocker som löst
        execute(
            "UPDATE task_blocker SET status='resolved', resolved_at=NOW(), resolution_note=%s WHERE id=%s",
            (body.resolution_note, blocker_id)
        )

        # Kolla om det finns fler aktiva blockers
        remaining = run_psql(RM_CENTRAL_DB, f"""
            SELECT COUNT(*) as cnt FROM task_blocker
            WHERE task_id = '{_sq(str(task_id))}' AND status = 'active' AND id != '{_sq(blocker_id)}'
        """)

        if remaining and remaining[0]["cnt"] == 0:
            # Sista blockern löst — flytta tillbaka till inbox
            execute(
                "UPDATE rm_task SET board_column='inbox', updated_at=NOW() WHERE id=%s AND board_column='waiting'",
                (str(task_id),)
            )

        _log_task_activity(str(task_id), "blocker_resolved",
                           new_value=body.resolution_note or "Löst",
                           actor=user.get("name"))

        return {"ok": True, "remaining_blockers": remaining[0]["cnt"] if remaining else 0}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/blockers/{blocker_id}/follow-up")
async def hub_follow_up_blocker(blocker_id: str, body: BlockerFollowUp, user: dict = Depends(get_current_user)):
    """Registrera uppföljning på en blocker."""
    try:
        execute(
            """UPDATE task_blocker
               SET follow_up_count = follow_up_count + 1,
                   last_follow_up_at = NOW(),
                   follow_up_date = %s,
                   note = COALESCE(%s, note)
               WHERE id = %s AND status = 'active'""",
            (body.next_follow_up_date, body.note, blocker_id)
        )

        # Hämta task_id för activity-logg
        blocker = run_psql(RM_CENTRAL_DB, f"SELECT task_id FROM task_blocker WHERE id = '{_sq(blocker_id)}'")
        if blocker:
            _log_task_activity(str(blocker[0]["task_id"]), "followed_up",
                               new_value=body.note or "Uppföljning registrerad",
                               actor=user.get("name"))

        return {"ok": True}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


