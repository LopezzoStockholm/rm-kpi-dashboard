# Recurring Templates & Daily Checklist
# ============================================================================

class RecurringTemplateCreate(BaseModel):
    title: str
    description: Optional[str] = None
    process_area: str
    frequency: str  # daily, weekly, monthly, quarterly, halfyear, yearly
    rrule: Optional[str] = None
    deadline_rule: Optional[str] = None
    deadline_offset_days: int = 0
    deadline_anchor: str = "period_start"
    assignee_email: Optional[str] = None
    backup_email: Optional[str] = None
    priority: int = 2
    task_type: str = "action"
    context: Optional[str] = None
    planner_plan_id: Optional[str] = None
    lookahead_days: int = 7
    active: bool = True

class RecurringTemplateUpdate(BaseModel):
    title: Optional[str] = None
    description: Optional[str] = None
    process_area: Optional[str] = None
    frequency: Optional[str] = None
    rrule: Optional[str] = None
    deadline_rule: Optional[str] = None
    deadline_offset_days: Optional[int] = None
    deadline_anchor: Optional[str] = None
    assignee_email: Optional[str] = None
    backup_email: Optional[str] = None
    priority: Optional[int] = None
    task_type: Optional[str] = None
    context: Optional[str] = None
    planner_plan_id: Optional[str] = None
    lookahead_days: Optional[int] = None
    active: Optional[bool] = None

class ChecklistMark(BaseModel):
    status: str  # done, pending
    comment: Optional[str] = None


@app.get("/api/hub/recurring")
async def hub_list_recurring(
    user: dict = Depends(get_current_user),
    active_only: bool = True,
    process_area: Optional[str] = None,
    frequency: Optional[str] = None,
):
    """Lista recurring templates. VD ser alla, övriga ser sina tilldelade."""
    try:
        conditions = ["company_code = 'RM'"]
        if active_only:
            conditions.append("active = true")
        if process_area:
            conditions.append(f"process_area = '{_sq(process_area)}'")
        if frequency:
            conditions.append(f"frequency = '{_sq(frequency)}'")
        if not has_perm(user, "admin.recurring"):
            conditions.append(f"assignee_email = '{_sq(user.get('email', ''))}'")

        where = " AND ".join(conditions)
        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT id, title, description, process_area, frequency, rrule,
                   deadline_rule, deadline_offset_days, deadline_anchor,
                   assignee_email, backup_email, priority, task_type,
                   context, planner_plan_id, lookahead_days, active,
                   next_generate_at::text, last_generated_at::text,
                   created_at::text, updated_at::text
            FROM recurring_template
            WHERE {where}
            ORDER BY process_area, frequency, title
        """)
        return {"ok": True, "templates": rows, "count": len(rows)}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/api/hub/recurring")
async def hub_create_recurring(
    body: RecurringTemplateCreate,
    user: dict = Depends(get_current_user),
):
    """Skapa ny recurring template. Kräver VD-roll."""
    require_perm(user, "admin.recurring")
    try:
        new_id = execute(
            """INSERT INTO recurring_template
               (company_code, title, description, process_area, frequency, rrule,
                deadline_rule, deadline_offset_days, deadline_anchor,
                assignee_email, backup_email, priority, task_type,
                context, planner_plan_id, lookahead_days, active)
               VALUES ('RM', %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
               RETURNING id""",
            (
                body.title, body.description, body.process_area,
                body.frequency, body.rrule, body.deadline_rule,
                body.deadline_offset_days, body.deadline_anchor,
                body.assignee_email, body.backup_email, body.priority,
                body.task_type, body.context, body.planner_plan_id,
                body.lookahead_days, body.active,
            ),
            returning=True,
        )
        return {"ok": True, "id": new_id}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/recurring/{template_id}")
async def hub_update_recurring(
    template_id: int,
    body: RecurringTemplateUpdate,
    user: dict = Depends(get_current_user),
):
    """Uppdatera recurring template. Kräver VD-roll."""
    require_perm(user, "admin.recurring")
    try:
        updates = []
        values = []
        for field, val in body.dict(exclude_unset=True).items():
            updates.append(f"{field} = %s")
            values.append(val)
        if not updates:
            raise HTTPException(status_code=400, detail="Inga fält att uppdatera")
        updates.append("updated_at = NOW()")
        values.append(template_id)
        sql = f"UPDATE recurring_template SET {', '.join(updates)} WHERE id = %s"
        execute(sql, tuple(values))
        return {"ok": True}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.delete("/api/hub/recurring/{template_id}")
async def hub_deactivate_recurring(
    template_id: int,
    user: dict = Depends(get_current_user),
):
    """Avaktivera (soft-delete) recurring template. Kräver VD-roll."""
    require_perm(user, "admin.recurring")
    try:
        execute(
            "UPDATE recurring_template SET active = false, updated_at = NOW() WHERE id = %s",
            (template_id,),
        )
        return {"ok": True}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


# ── Daily Checklist ──

@app.get("/api/hub/checklist/today")
async def hub_checklist_today(
    user: dict = Depends(get_current_user),
):
    """Hämta dagens checklista. Visar items tilldelade inloggad användare (VD ser alla)."""
    try:
        today = date.today().isoformat()
        email_filter = ""
        if not has_perm(user, "checklist.read_all"):
            email_filter = f"AND rt.assignee_email = '{_sq(user.get('email', ''))}'"

        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT cl.id, cl.template_id, cl.check_date::text,
                   cl.status, cl.checked_by, cl.checked_at::text, cl.comment,
                   rt.title, rt.description, rt.process_area,
                   rt.assignee_email, rt.backup_email, rt.context
            FROM daily_checklist_log cl
            JOIN recurring_template rt ON rt.id = cl.template_id
            WHERE cl.check_date = '{today}' {email_filter}
            ORDER BY rt.process_area, rt.title
        """)
        done = sum(1 for r in rows if r.get("status") == "done")
        return {
            "ok": True,
            "date": today,
            "items": rows,
            "total": len(rows),
            "done": done,
            "pending": len(rows) - done,
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.patch("/api/hub/checklist/{item_id}")
async def hub_checklist_mark(
    item_id: int,
    body: ChecklistMark,
    user: dict = Depends(get_current_user),
):
    """Markera checklist-item som done/pending."""
    try:
        if body.status == "done":
            execute(
                """UPDATE daily_checklist_log
                   SET status = 'done', checked_by = %s, checked_at = NOW(), comment = %s
                   WHERE id = %s""",
                (user.get("email", user.get("username")), body.comment, item_id),
            )
        else:
            execute(
                """UPDATE daily_checklist_log
                   SET status = 'pending', checked_by = NULL, checked_at = NULL, comment = NULL
                   WHERE id = %s""",
                (item_id,),
            )
        return {"ok": True}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/checklist/history")
async def hub_checklist_history(
    user: dict = Depends(get_current_user),
    days: int = 14,
    assignee: Optional[str] = None,
):
    """Historik för daglig checklista. Default 14 dagar bakåt."""
    try:
        email_filter = ""
        if assignee:
            email_filter = f"AND rt.assignee_email = '{_sq(assignee)}'"
        elif not has_perm(user, "checklist.read_all"):
            email_filter = f"AND rt.assignee_email = '{_sq(user.get('email', ''))}'"

        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT cl.id, cl.template_id, cl.check_date::text,
                   cl.status, cl.checked_by, cl.checked_at::text, cl.comment,
                   rt.title, rt.process_area, rt.assignee_email
            FROM daily_checklist_log cl
            JOIN recurring_template rt ON rt.id = cl.template_id
            WHERE cl.check_date >= CURRENT_DATE - {days}
              {email_filter}
            ORDER BY cl.check_date DESC, rt.process_area, rt.title
        """)

        # Summera per dag
        from collections import defaultdict
        daily_stats = defaultdict(lambda: {"done": 0, "pending": 0, "missed": 0})
        for r in rows:
            d = r.get("check_date", "")
            s = r.get("status", "pending")
            if s in daily_stats[d]:
                daily_stats[d][s] += 1

        return {
            "ok": True,
            "items": rows,
            "daily_stats": dict(daily_stats),
            "days": days,
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/hub/checklist/stats")
async def hub_checklist_stats(
    user: dict = Depends(get_current_user),
    days: int = 30,
):
    """Aggregerad statistik för checklist-genomförande."""
    try:
        email_filter = ""
        if not has_perm(user, "checklist.read_all"):
            email_filter = f"AND rt.assignee_email = '{_sq(user.get('email', ''))}'"

        rows = run_psql(RM_CENTRAL_DB, f"""
            SELECT rt.assignee_email,
                   COUNT(*) as total,
                   COUNT(*) FILTER (WHERE cl.status = 'done') as done,
                   COUNT(*) FILTER (WHERE cl.status = 'missed') as missed,
                   COUNT(*) FILTER (WHERE cl.status = 'pending') as pending
            FROM daily_checklist_log cl
            JOIN recurring_template rt ON rt.id = cl.template_id
            WHERE cl.check_date >= CURRENT_DATE - {days}
              {email_filter}
            GROUP BY rt.assignee_email
            ORDER BY rt.assignee_email
        """)
        return {"ok": True, "stats": rows, "days": days}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
