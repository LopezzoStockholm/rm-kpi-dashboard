@app.get("/api/hub/blockers/overdue")
async def hub_overdue_blockers(user: dict = Depends(get_current_user)):
    """Lista alla aktiva blockers som passerat follow_up_date."""
    rows = run_psql(RM_CENTRAL_DB, """
        SELECT b.id, b.task_id, b.blocker_type, b.waiting_for_name,
               b.waiting_for_email, b.waiting_for_org,
               b.follow_up_date, b.follow_up_count, b.last_follow_up_at,
               b.escalated, b.note, b.waiting_since,
               t.title as task_title, t.assignee_email, t.project_code,
               t.board_column, t.created_by
        FROM task_blocker b
        JOIN rm_task t ON t.id = b.task_id
        WHERE b.status = 'active'
          AND b.follow_up_date <= CURRENT_DATE
        ORDER BY b.follow_up_date ASC, b.follow_up_count DESC
    """)
