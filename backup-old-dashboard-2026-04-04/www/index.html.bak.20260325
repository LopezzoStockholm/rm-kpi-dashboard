<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RM KPI Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0D1117;
            color: #E6EDF3;
            line-height: 1.5;
            padding: 24px;
        }
        .container { max-width: 1600px; margin: 0 auto; }

        /* HEADER */
        .header { margin-bottom: 32px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 16px; }
        .header h1 { font-size: 32px; font-weight: 700; color: #E6EDF3; margin-bottom: 4px; }
        .header p { font-size: 14px; color: #8B949E; }
        .filters { display: flex; gap: 12px; align-items: center; }
        .filter-group label { font-size: 11px; color: #8B949E; text-transform: uppercase; letter-spacing: 0.5px; margin-right: 6px; }
        .filter-group select {
            padding: 7px 12px; border: 1px solid #21262D; border-radius: 6px;
            background: #161B22; color: #E6EDF3; font-family: 'Inter', sans-serif; font-size: 13px; cursor: pointer;
        }
        .filter-group select:hover { border-color: #30363D; }
        .filter-group select option { background: #161B22; }

        /* KPI CARDS */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .kpi-card {
            background: #161B22;
            border: 1px solid #21262D;
            border-radius: 8px;
            padding: 20px;
            transition: border-color 0.3s ease;
        }
        .kpi-card:hover { border-color: #30363D; }
        .kpi-label {
            font-size: 12px; font-weight: 600; color: #8B949E;
            text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;
        }
        .kpi-value { font-size: 28px; font-weight: 700; color: #58A6FF; margin-bottom: 8px; }
        .kpi-subtext { font-size: 12px; color: #8B949E; line-height: 1.6; }
        .progress-bar { height: 6px; background: #21262D; border-radius: 3px; overflow: hidden; margin-top: 12px; }
        .progress-fill { height: 100%; border-radius: 3px; transition: width 0.8s ease-out; }

        /* SECTION TITLE */
        .section-title {
            font-size: 16px; font-weight: 600; color: #E6EDF3; margin-bottom: 16px;
            display: flex; align-items: center; gap: 8px;
        }
        .badge {
            display: inline-block; padding: 4px 10px; border-radius: 4px;
            font-size: 11px; font-weight: 600;
        }
        .badge.live { background: #3FB950; color: #0D1117; }

        /* CARDS */
        .card {
            background: #161B22;
            border: 1px solid #21262D;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 16px;
        }
        .card:hover { border-color: #30363D; }

        /* GRID LAYOUTS */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px; }
        .grid-full { grid-column: 1 / -1; }
        @media (max-width: 1200px) { .grid-2 { grid-template-columns: 1fr; } }

        /* CHART */
        .chart-area { position: relative; height: 300px; margin-top: 12px; }
        .chart-area-sm { position: relative; height: 120px; margin-top: 12px; }

        /* HITRATE MATRIX */
        .matrix-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .matrix-table th {
            padding: 10px 12px; text-align: left; font-weight: 600; color: #8B949E;
            font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;
            border-bottom: 2px solid #21262D;
        }
        .matrix-table td { padding: 10px 12px; border-bottom: 1px solid #21262D; text-align: right; }
        .matrix-table td:first-child { text-align: left; font-weight: 600; color: #E6EDF3; text-transform: capitalize; }
        .matrix-table tr:hover td { background: #0D1117; }
        .hr-cell {
            display: inline-block; padding: 3px 10px; border-radius: 4px;
            font-size: 11px; font-weight: 600; min-width: 48px; text-align: center;
        }
        .hr-high { background: rgba(63,185,80,0.15); color: #3FB950; }
        .hr-mid { background: rgba(249,115,22,0.15); color: #F97316; }
        .hr-low { background: rgba(248,81,73,0.15); color: #F85149; }

        /* PROJECTS TABLE */
        .projects-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .projects-table thead { background: #0D1117; border-bottom: 2px solid #21262D; }
        .projects-table th {
            padding: 12px; text-align: left; font-weight: 600; color: #8B949E;
            text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px;
            cursor: pointer; user-select: none; white-space: nowrap;
        }
        .projects-table th:hover { color: #E6EDF3; }
        .projects-table td { padding: 12px; border-bottom: 1px solid #21262D; color: #E6EDF3; }
        .projects-table tr:hover td { background: #0D1117; }
        .projects-table .text-right { text-align: right; }
        .projects-table .mono { font-variant-numeric: tabular-nums; }
        .projects-table .tb1-positive { color: #3FB950; font-weight: 600; }
        .projects-table .tb1-negative { color: #F85149; font-weight: 600; }

        /* DEAL TABLE */
        .deals-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .deals-table thead { background: #0D1117; border-bottom: 2px solid #21262D; }
        .deals-table th {
            padding: 12px; text-align: left; font-weight: 600; color: #8B949E;
            text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px;
            cursor: pointer; user-select: none; white-space: nowrap;
        }
        .deals-table th:hover { color: #E6EDF3; }
        .deals-table td { padding: 12px; border-bottom: 1px solid #21262D; color: #E6EDF3; }
        .deals-table tr:hover td { background: #0D1117; }
        .deals-table .text-right { text-align: right; }
        .deals-table .mono { font-variant-numeric: tabular-nums; }

        /* STATUS TAGS */
        .tag {
            display: inline-block; padding: 4px 10px; border-radius: 4px;
            font-size: 11px; font-weight: 600;
        }
        .tag-kall { background: rgba(248,81,73,0.15); color: #F85149; }
        .tag-varm { background: rgba(249,115,22,0.15); color: #F97316; }
        .tag-styrd { background: rgba(88,166,255,0.15); color: #58A6FF; }
        .tag-service { background: rgba(210,153,34,0.15); color: #D29922; }
        .tag-intern { background: rgba(63,185,80,0.15); color: #3FB950; }

        .stage-inkommit { background: rgba(139,148,158,0.15); color: #8B949E; }
        .stage-kalkyl { background: rgba(88,166,255,0.15); color: #58A6FF; }
        .stage-offert_skickad { background: rgba(249,115,22,0.15); color: #F97316; }
        .stage-forhandling { background: rgba(210,153,34,0.15); color: #D29922; }
        .stage-kontrakterat { background: rgba(63,185,80,0.15); color: #3FB950; }
        .stage-leverans { background: rgba(63,185,80,0.25); color: #3FB950; }
        .stage-fakturerat { background: rgba(63,185,80,0.35); color: #3FB950; }

        /* STAGE LEGEND */
        .stage-legend { display: flex; flex-direction: column; gap: 8px; margin-top: 16px; }
        .stage-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 10px 12px; background: #0D1117; border-radius: 4px;
            border-left: 3px solid #58A6FF; font-size: 13px;
        }
        .stage-amount { font-weight: 600; }

        /* COLORS */
        .text-blue { color: #58A6FF; }
        .text-green { color: #3FB950; }
        .text-orange { color: #F97316; }
        .text-red { color: #F85149; }
        .text-muted { color: #8B949E; }
        .text-gold { color: #D29922; }

        /* FOOTER */
        .footer {
            text-align: center; padding-top: 24px; margin-top: 16px;
            border-top: 1px solid #21262D; color: #8B949E; font-size: 12px;
        }

        @media (max-width: 900px) {
            .kpi-grid { grid-template-columns: 1fr 1fr; }
            body { padding: 16px; }
        }
        @media print {
            body { background: #fff; color: #000; }
            .card, .kpi-card { border: 1px solid #ddd; background: #fff; }
            .filters { display: none; }
        }
    
        /* FORECAST TOGGLE */
        .forecast-toggle {
            padding: 6px 16px; border: 1px solid #21262D; border-radius: 6px;
            background: #0D1117; color: #8B949E; font-family: 'Inter', sans-serif;
            font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s;
        }
        .forecast-toggle:hover { border-color: #58A6FF; color: #E6EDF3; }
        .forecast-toggle.active { background: #58A6FF; color: #0D1117; border-color: #58A6FF; }

        /* COLLAPSIBLE SECTIONS */
        .collapsible-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 0; cursor: pointer; user-select: none;
            border-top: 1px solid #21262D; margin-top: 8px;
        }
        .collapsible-header:hover { opacity: 0.85; }
        .collapsible-header h3 {
            font-size: 16px; font-weight: 600; color: #E6EDF3; margin: 0;
            display: flex; align-items: center; gap: 8px;
        }
        .collapsible-header .ch-summary {
            font-size: 12px; color: #8B949E; font-weight: 400; margin-left: 12px;
        }
        .collapsible-chevron {
            width: 20px; height: 20px; color: #8B949E; transition: transform 0.2s;
            flex-shrink: 0;
        }
        .collapsible-header.open .collapsible-chevron { transform: rotate(180deg); }
        .collapsible-body { display: none; padding-bottom: 8px; }
        .collapsible-body.open { display: block; }
    </style>
</head>
<body>
<div class="container">
    <!-- HEADER -->
    <div class="header">
        <div>
            <h1>RM Entreprenad och Fasad</h1>
            <p>Pipeline Dashboard — realtidsdata fr&aring;n Twenty CRM</p>
        </div>
        <div class="filters">
            <div class="filter-group">
                <label>Steg</label>
                <select id="filter-stage" onchange="dashboard.applyFilters()">
                    <option value="all">Alla steg</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Typ</label>
                <select id="filter-type" onchange="dashboard.applyFilters()">
                    <option value="all">Alla typer</option>
                </select>
            </div>
        </div>
    </div>

    <!-- KPI RAD 1 -->
    <div class="kpi-grid" id="kpi-row-1"></div>

    <!-- KPI RAD 2 -->
    <div class="kpi-grid" id="kpi-row-2" style="margin-top:-16px"></div>

    <!-- EKONOMI SECTION (Fortnox) -->
    <div id="fortnox-section" style="display:none">
        <div style="margin-bottom:16px;padding-top:8px;border-top:2px solid #21262D">
            <div class="section-title" style="font-size:20px">Ekonomi <span class="badge live">Fortnox</span></div>
        </div>
        <div class="kpi-grid" id="finance-kpi-row"></div>
        <div class="collapsible-header" data-section="sec-top5" onclick="toggleSection('sec-top5')">
            <h3>Topp 5 kunder &amp; leverant&ouml;rer</h3>
            <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
        </div>
        <div id="sec-top5" class="collapsible-body">
        <div class="grid-2">
            <div class="card">
                <div class="section-title">Topp 5 kunder (oms&auml;ttning)</div>
                <div id="top-customers-table" style="overflow-x:auto"></div>
            </div>
            <div class="card">
                <div class="section-title">Topp 5 leverant&ouml;rer (kostnad)</div>
                <div id="top-suppliers-table" style="overflow-x:auto"></div>
            </div>
        </div>
        </div>
        <div class="grid-2">
            <div class="card">
                <div class="section-title">F&ouml;rfallna kundfakturor</div>
                <div id="overdue-invoices-table" style="overflow-x:auto"></div>
            </div>
            <div class="card">
                <div class="section-title" style="color:#D29922">Parkerade leverant&ouml;rsfakturor <span id="si-parkerad-badge" class="tag" style="background:rgba(210,153,34,0.15);color:#D29922;font-size:11px;margin-left:6px"></span></div>
                <div id="si-parkerad-table" style="overflow-x:auto"></div>
            </div>
        </div>
        <div class="grid-2">
            <div class="card">
                <div class="section-title" style="color:#58A6FF">Bevakade leverant&ouml;rsfakturor <span id="si-bevakas-badge" class="tag" style="background:rgba(88,166,255,0.15);color:#58A6FF;font-size:11px;margin-left:6px"></span></div>
                <div id="si-bevakas-table" style="overflow-x:auto"></div>
            </div>
            <div class="card">
                <div class="section-title" style="color:#F85149">F&ouml;rfallna leverant&ouml;rsfakturor <span id="si-overdue-badge" class="tag" style="background:rgba(248,81,73,0.15);color:#F85149;font-size:11px;margin-left:6px"></span></div>
                <div id="si-overdue-table" style="overflow-x:auto"></div>
            </div>
        </div>
        <div class="collapsible-header" data-section="sec-charts-eco" onclick="toggleSection('sec-charts-eco')">
            <h3>Kassafl&ouml;de &amp; TB1-diagram</h3>
            <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
        </div>
        <div id="sec-charts-eco" class="collapsible-body">
        <div class="grid-2">
            <div class="card">
                <div class="section-title">Kassafl&ouml;de (fordringar vs skulder)</div>
                <div class="chart-area"><canvas id="chart-cashflow"></canvas></div>
            </div>
            <div class="card">
                <div class="section-title">TB1 &mdash; int&auml;kter vs kostnader</div>
                <div class="chart-area"><canvas id="chart-tb1"></canvas></div>
            </div>
        </div>
        </div>
    </div>

    <!-- LIKVIDITETSPROGNOS SECTION -->
    <div id="forecast-section" style="display:none">
        <div style="margin-bottom:16px;padding-top:8px;border-top:2px solid #21262D">
            <div class="section-title" style="font-size:20px">
                Kassafl&ouml;desprognos <span id="forecast-weeks-label">8 veckor</span> fram&aring;t
                <span id="forecast-alert-badge" class="badge" style="display:none;margin-left:8px;font-size:11px"></span>
            </div>
            <div style="display:flex;gap:8px;margin-top:8px">
                <button class="forecast-toggle active" data-weeks="8" onclick="dashboard.setForecastWeeks(8)">8 veckor</button>
                <button class="forecast-toggle" data-weeks="26" onclick="dashboard.setForecastWeeks(26)">26 veckor</button>
                <button class="forecast-toggle" data-weeks="52" onclick="dashboard.setForecastWeeks(52)">52 veckor</button>
            </div>
        </div>
        <div class="card">
            <div class="chart-area" style="height:360px"><canvas id="chart-forecast"></canvas></div>
            <div style="display:flex;justify-content:space-between;margin-top:12px;font-size:12px;color:#8B949E">
                <div>Gr&ouml;nt = Inbetalningar (kundfordringar) &middot; R&ouml;tt = Utbetalningar (lev.skulder) &middot; Bl&aring; linje = Kumulativ kassa</div>
                <div id="forecast-summary" style="font-weight:600"></div>
            </div>
        </div>
    </div>

            <!-- PROJECTS SECTION -->
    <div class="collapsible-header" data-section="sec-projects" onclick="toggleSection('sec-projects')">
        <h3>Projektlönsamhet &mdash; pågående projekt</h3>
        <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
    </div>
    <div id="sec-projects" class="collapsible-body">
        <div class="card">
            <div id="projects-container" style="display:none">
                <div class="section-title" style="margin-bottom:12px">Grupperad vy</div>
                <div style="overflow-x:auto">
                    <table class="projects-table">
                        <thead>
                            <tr>
                                <th>Projekt</th>
                                <th>Ledare</th>
                                <th class="text-right">Intäkter</th>
                                <th class="text-right">Kostnader</th>
                                <th class="text-right">TB1</th>
                                <th class="text-right">TB1%</th>
                                <th class="text-right">Fakturor (K/L)</th>
                            </tr>
                        </thead>
                        <tbody id="project-groups-tbody"></tbody>
                    </table>
                </div>
                <div style="margin-top:24px">
                    <div class="section-title" style="margin-bottom:12px;cursor:pointer" onclick="document.getElementById('detail-projects').style.display=document.getElementById('detail-projects').style.display==='none'?'block':'none'">Detaljvy per projektkod &#9662;</div>
                    <div id="detail-projects" style="display:none;overflow-x:auto">
                        <table class="projects-table">
                            <thead>
                                <tr>
                                    <th>Kod</th>
                                    <th>Beskrivning</th>
                                    <th>Grupp</th>
                                    <th>Ledare</th>
                                    <th class="text-right">Intäkter</th>
                                    <th class="text-right">Kostnader</th>
                                    <th class="text-right">TB1</th>
                                    <th class="text-right">TB1%</th>
                                    <th class="text-right">Fakturor (K/L)</th>
                                </tr>
                            </thead>
                            <tbody id="projects-tbody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div id="projects-empty" style="padding:20px;text-align:center;color:#8B949E">
                Ingen projektdata tillgänglig
            </div>
        </div>
    </div>

<div class="collapsible-header" data-section="sec-pipeline" onclick="toggleSection('sec-pipeline')">
            <h3>Pipeline &mdash; aff&auml;rstyp &amp; topp 10</h3>
            <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
        </div>
        <div id="sec-pipeline" class="collapsible-body">
    <!-- PIPELINE SECTION -->
    <div class="grid-2">
        <div class="card">
            <div class="section-title">Pipeline per aff&auml;rstyp</div>
            <div class="chart-area-sm"><canvas id="chart-type-bar"></canvas></div>
            <div id="type-legend" class="stage-legend"></div>
        </div>
        <div class="card">
            <div class="section-title">10 st&ouml;rsta aff&auml;rer</div>
            <div id="top10-table" style="overflow-x:auto"></div>
        </div>
    </div>
        </div>

        <div class="collapsible-header" data-section="sec-pipeline-charts" onclick="toggleSection('sec-pipeline-charts')">
            <h3>Pipeline-diagram (per steg)</h3>
            <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
        </div>
        <div id="sec-pipeline-charts" class="collapsible-body">
    <!-- CHARTS -->
    <div class="grid-2">
        <div class="card">
            <div class="section-title">Pipelinev&auml;rde per steg (Mkr)</div>
            <div class="chart-area"><canvas id="chart-stage-value"></canvas></div>
        </div>
        <div class="card">
            <div class="section-title">Uppskattat vs viktat per steg</div>
            <div class="chart-area"><canvas id="chart-stage-compare"></canvas></div>
        </div>
    </div>
        </div>

        <div class="collapsible-header" data-section="sec-stacked" onclick="toggleSection('sec-stacked')">
            <h3>Pipeline per steg &amp; typ (staplat)</h3>
            <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
        </div>
        <div id="sec-stacked" class="collapsible-body">
    <!-- STACKED -->
    <div class="card" style="margin-bottom:32px">
        <div class="section-title">Pipeline per steg och aff&auml;rstyp (Mkr)</div>
        <div class="chart-area"><canvas id="chart-stacked"></canvas></div>
    </div>
        </div>

        <div class="collapsible-header" data-section="sec-hitrate" onclick="toggleSection('sec-hitrate')">
            <h3>Hitrate-matris</h3>
            <svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>
        </div>
        <div id="sec-hitrate" class="collapsible-body">
    <!-- HITRATE MATRIX -->
    <div class="card" style="margin-bottom:32px">
        <div class="section-title">Hitrate-matris <span class="badge live">Live</span></div>
