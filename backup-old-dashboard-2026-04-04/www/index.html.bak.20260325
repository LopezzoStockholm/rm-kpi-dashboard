 "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V35", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V36", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V37", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V38", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V39", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V40", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V41", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V42", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V43", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V44", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V45", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V46", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V47", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V48", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V49", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V50", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V51", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V52", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V1", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V2", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V3", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V4", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V5", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V6", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V7", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V8", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V9", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V10", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V11", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}, {"label": "V12", "inbetalningar": 0, "inbetalningar_viktat": 0, "utbetalningar": 0, "utbetalningar_justerat": 0}], "has_data": true, "app_id": "2ff09e533f9447aa8082ee963f9f810e"};

// ═══════════════════════════════════════════════════════════
// CONSTANTS
// ═══════════════════════════════════════════════════════════
const STAGE_ORDER = ['inkommit','kalkyl','offert_skickad','forhandling','kontrakterat','leverans','fakturerat'];
const STAGE_LABELS = {inkommit:'Inkommit',kalkyl:'Kalkyl',offert_skickad:'Offert skickad',forhandling:'Förhandling',kontrakterat:'Kontrakterat',leverans:'Leverans',fakturerat:'Fakturerat'};
const TYPE_ORDER = ['intern','varm','styrd','service','kall'];
const TYPE_LABELS = {kall:'Kall',varm:'Varm',styrd:'Styrd',service:'Service',intern:'Intern'};
const TYPE_COLORS = {kall:'#F85149',varm:'#F97316',styrd:'#58A6FF',service:'#D29922',intern:'#3FB950'};
const TYPE_BG = {kall:'rgba(248,81,73,0.15)',varm:'rgba(249,115,22,0.15)',styrd:'rgba(88,166,255,0.15)',service:'rgba(210,153,34,0.15)',intern:'rgba(63,185,80,0.15)'};
const STAGE_COLORS_MAP = {inkommit:'#8B949E',kalkyl:'#58A6FF',offert_skickad:'#F97316',forhandling:'#D29922',kontrakterat:'#3FB950',leverans:'#3FB950',fakturerat:'#3FB950'};

// Chart.js global defaults
Chart.defaults.color = '#8B949E';
Chart.defaults.borderColor = '#21262D';
Chart.defaults.font.family = "'Inter', sans-serif";

// ═══════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════
function fmt(v) {
    if (v >= 1e6) return (v/1e6).toFixed(1).replace('.0','') + ' Mkr';
    if (v >= 1e3) return Math.round(v/1e3) + ' tkr';
    if (v === 0) return '0';
    return v.toLocaleString('sv-SE') + ' kr';
}
function fmtShort(v) {
    if (v >= 1e6) return (v/1e6).toFixed(1).replace('.0','') + ' M';
    if (v >= 1e3) return Math.round(v/1e3) + ' k';
    return v.toString();
}

// ═══════════════════════════════════════════════════════════
// DASHBOARD CLASS
// ═══════════════════════════════════════════════════════════

function toggleSection(id) {
    var header = document.querySelector('[data-section="' + id + '"]');
    var body = document.getElementById(id);
    if (!header || !body) return;
    header.classList.toggle('open');
    body.classList.toggle('open');
}
const CHEVRON_SVG = '<svg class="collapsible-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"/></svg>';

const LABEL_API_URL = 'http://161.35.79.92:8082';
const LABEL_API_KEY = 'rm-label-2026';

function setSupplierLabel(fortnoxId, label) {
    fetch(LABEL_API_URL + '/api/label', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Api-Key': LABEL_API_KEY},
        body: JSON.stringify({type: 'supplier', fortnox_id: fortnoxId, label: label})
    }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) {
            // Update local data and re-sort into correct table
            var allSi = FORTNOX.all_supplier_invoices || [];
            for (var i = 0; i < allSi.length; i++) {
                if (String(allSi[i].fortnox_id) === String(fortnoxId)) {
                    allSi[i].label = label;
                    break;
                }
            }
            // Re-render by triggering dashboard refresh of the supplier sections
            if (window._dashboard) window._dashboard.renderFinancials();
        } else {
            alert('Kunde inte uppdatera etikett: ' + (d.error || 'ok\u00e4nt fel'));
        }
    }).catch(function(e) {
        alert('API-fel: ' + e.message);
    });
}

class Dashboard {
    constructor(data) {
        this.rawData = data;
        this.filteredData = data;
        this.charts = {};
        this.sortCol = 'estimated_value';
        this.sortDir = 'desc';
        this.init();
    }

    init() {
        this.populateFilters();
        this.renderKPIs();
        this.renderCharts();
        this.renderTypeLegend();
        this.renderTop10();
        this.renderHitrateMatrix();
        this.renderDealTable();
        if (FORTNOX.has_data) this.renderFinancials();
        if (FORTNOX.has_data && FORTNOX.forecast_weeks) this.renderForecast(8);
        if (FORTNOX.has_data && (FORTNOX.projects || FORTNOX.project_groups)) this.renderProjects();
        document.getElementById('data-date').textContent = new Date().toLocaleString('sv-SE');
    }

    populateFilters() {
        const ss = document.getElementById('filter-stage');
        STAGE_ORDER.forEach(s => { const o = document.createElement('option'); o.value = s; o.textContent = STAGE_LABELS[s]; ss.appendChild(o); });
        const ts = document.getElementById('filter-type');
        TYPE_ORDER.forEach(t => { const o = document.createElement('option'); o.value = t; o.textContent = TYPE_LABELS[t]; ts.appendChild(o); });
    }

    applyFilters() {
        const stage = document.getElementById('filter-stage').value;
        const type = document.getElementById('filter-type').value;
        this.filteredData = this.rawData.filter(d => {
            if (stage !== 'all' && d.stage !== stage) return false;
            if (type !== 'all' && d.deal_type !== type) return false;
            return true;
        });
        this.renderKPIs();
        Object.values(this.charts).forEach(c => c.destroy());
        this.renderCharts();
        this.renderTypeLegend();
        this.renderTop10();
        this.renderDealTable();
    }

    // ─── KPIs ─────────────────────────────────────────────
    renderKPIs() {
        const d = this.filteredData;
        const total = d.reduce((s,r) => s + r.estimated_value, 0);
        const weighted = d.reduce((s,r) => s + r.estimated_value * r.hit_rate / 100, 0);
        const count = d.length;
        const withValue = d.filter(r => r.estimated_value > 0).length;
        const wAvgHr = total > 0 ? (weighted / total * 100) : 0;

        // Per type breakdown
        const byType = {};
        TYPE_ORDER.forEach(t => byType[t] = {value:0, weighted:0, count:0});
        d.forEach(r => { if(byType[r.deal_type]) { byType[r.deal_type].value += r.estimated_value; byType[r.deal_type].weighted += r.estimated_value * r.hit_rate/100; byType[r.deal_type].count++; }});

        // External = not intern
        const extVal = d.filter(r => r.deal_type !== 'intern' && (r.stage === 'kontrakterat' || r.stage === 'forhandling')).reduce((s,r) => s + r.estimated_value, 0);
        const intVal = d.filter(r => r.deal_type === 'intern').reduce((s,r) => s + r.estimated_value, 0);

        // KPI row 1 — all cards link to Twenty CRM opportunities
        const twentyUrl = 'http://161.35.79.92:3001/objects/opportunities';
        const kpiLink = (inner) => `<a href="${twentyUrl}" target="_blank" style="color:inherit;text-decoration:none;display:block">${inner}</a>`;

        document.getElementById('kpi-row-1').innerHTML = `
            <div class="kpi-card" style="cursor:pointer" onclick="window.open('${twentyUrl}','_blank')">
                <div class="kpi-label">Viktad pipeline</div>
                <div class="kpi-value">${fmt(weighted)}</div>
                <div class="kpi-subtext">${count} aff\u00e4rer \u00d7 hitrate per typ</div>
                <div style="font-size:11px;color:#8B949E;line-height:1.8;margin-top:8px">
                    ${TYPE_ORDER.filter(t => byType[t].count > 0).map(t =>
                        `<span style="color:${TYPE_COLORS[t]}">●</span> ${TYPE_LABELS[t]} ${fmt(byType[t].weighted)} (${byType[t].count} st)`
                    ).join('<br>')}
                </div>
            </div>
            <div class="kpi-card" style="cursor:pointer" onclick="window.open('${twentyUrl}','_blank')">
                <div class="kpi-label">Pipeline total (oviktat)</div>
                <div class="kpi-value">${fmt(total)}</div>
                <div class="kpi-subtext">${withValue} aff\u00e4rer med v\u00e4rde</div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width:100%;background:linear-gradient(90deg,${TYPE_ORDER.filter(t=>byType[t].value>0).map(t => {
                        const pct = total > 0 ? (byType[t].value/total*100) : 0;
                        return TYPE_COLORS[t] + ' ' + pct.toFixed(0) + '%';
                    }).join(',')})"></div>
                </div>
                <div style="font-size:10px;color:#8B949E;margin-top:6px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:4px">
                    ${TYPE_ORDER.filter(t => byType[t].value > 0).map(t =>
                        `<span style="color:${TYPE_COLORS[t]}">${TYPE_LABELS[t]} ${total>0?(byType[t].value/total*100).toFixed(0):'0'}%</span>`
                    ).join('')}
                </div>
            </div>
            <div class="kpi-card" style="cursor:pointer" onclick="window.open('${twentyUrl}?viewId=b89ba576-5da5-49c3-b8d9-627ef73887c3','_blank')">
                <div class="kpi-label">Intern orderstock</div>
                <div class="kpi-value text-green">${fmt(intVal)}</div>
                <div class="kpi-subtext">${byType.intern?.count || 0} interna aff\u00e4rer (100% hitrate)</div>
            </div>
            <div class="kpi-card" style="cursor:pointer" onclick="window.open('${twentyUrl}?viewId=b89ba576-5da5-49c3-b8d9-627ef73887c3','_blank')">
                <div class="kpi-label">Snitt hitrate (viktat)</div>
                <div class="kpi-value">${wAvgHr.toFixed(0)}%</div>
                <div class="kpi-subtext">Baserat p\u00e5 aff\u00e4rstyp \u00d7 stadie</div>
                <div style="font-size:11px;color:#8B949E;line-height:1.6;margin-top:6px">
                    ${TYPE_ORDER.map(t => `<span style="color:${TYPE_COLORS[t]}">${TYPE_LABELS[t]} ~${byType[t].value>0?Math.round(byType[t].weighted/byType[t].value*100):0}%</span>`).join(' \u00b7 ')}
                </div>
            </div>
        `;
    }

    // ─── TYPE LEGEND ──────────────────────────────────────
    renderTypeLegend() {
        const byType = {};
        TYPE_ORDER.forEach(t => byType[t] = {value:0, count:0});
        this.filteredData.forEach(r => { if(byType[r.deal_type]) { byType[r.deal_type].value += r.estimated_value; byType[r.deal_type].count++; }});

        document.getElementById('type-legend').innerHTML = TYPE_ORDER.filter(t => byType[t].count > 0).map(t =>
            `<div class="stage-item" style="border-left-color:${TYPE_COLORS[t]}">
                <span>${TYPE_LABELS[t]} (${byType[t].count} st)</span>
                <span class="stage-amount" style="color:${TYPE_COLORS[t]}">${fmt(byType[t].value)}</span>
            </div>`
        ).join('');
    }

    // ─── TOP 10 ───────────────────────────────────────────
    renderTop10() {
        const top = [...this.filteredData].sort((a,b) => b.estimated_value - a.estimated_value).slice(0, 10);
        let html = '<table class="deals-table"><thead><tr><th>Projekt</th><th>Belopp</th><th>Typ</th><th>Viktat</th></tr></thead><tbody>';
        top.forEach(r => {
            const w = r.estimated_value * r.hit_rate / 100;
            const nameLink = r.twenty_id ? '<a href="http://161.35.79.92:3001/object/opportunity/'+r.twenty_id+'" target="_blank" style="color:#58A6FF;text-decoration:none">'+r.name+'</a>' : r.name;
            html += `<tr>
                <td>${nameLink}</td>
                <td class="text-right mono">${fmtShort(r.estimated_value)}</td>
                <td><span class="tag tag-${r.deal_type}">${TYPE_LABELS[r.deal_type]||r.deal_type}</span></td>
                <td class="text-right mono" style="color:${w >= r.estimated_value * 0.5 ? '#3FB950' : '#8B949E'}">${fmtShort(w)}</td>
            </tr>`;
        });
        html += '</tbody></table>';
        document.getElementById('top10-table').innerHTML = html;
    }

    // ─── CHARTS ───────────────────────────────────────────
    renderCharts() {
        this.charts.typeBar = this.createTypeBarChart();
        this.charts.stageValue = this.createStageValueChart();
        this.charts.stageCompare = this.createStageCompareChart();
        this.charts.stacked = this.createStackedChart();
    }

    aggByStage() {
        const agg = {};
        STAGE_ORDER.forEach(s => agg[s] = {value:0, weighted:0, count:0});
        this.filteredData.forEach(d => { if(agg[d.stage]) { agg[d.stage].value += d.estimated_value; agg[d.stage].weighted += d.estimated_value*d.hit_rate/100; agg[d.stage].count++; }});
        return agg;
    }

    createTypeBarChart() {
        const byType = {};
        TYPE_ORDER.forEach(t => byType[t] = 0);
        this.filteredData.forEach(r => { if(byType[r.deal_type] !== undefined) byType[r.deal_type] += r.estimated_value; });
        const types = TYPE_ORDER.filter(t => byType[t] > 0);
        return new Chart(document.getElementById('chart-type-bar'), {
            type: 'bar',
            data: {
                labels: types.map(t => TYPE_LABELS[t]),
                datasets: [{ data: types.map(t => byType[t]/1e6), backgroundColor: types.map(t => TYPE_COLORS[t]+'cc'), borderRadius: 4 }]
            },
            options: {
                indexAxis: 'y', responsive: true, maintainAspectRatio: false,
                plugins: { legend:{display:false}, tooltip:{ callbacks:{ label: ctx => fmt(ctx.parsed.x*1e6) }}},
                scales: { x:{beginAtZero:true, ticks:{callback:v=>v+' M'}, grid:{color:'#21262D'}}, y:{grid:{display:false}} }
            }
        });
    }

    createStageValueChart() {
        const agg = this.aggByStage();
        const stages = STAGE_ORDER.filter(s => agg[s].count > 0);
        return new Chart(document.getElementById('chart-stage-value'), {
            type: 'bar',
            data: {
                labels: stages.map(s => STAGE_LABELS[s]),
                datasets: [{ data: stages.map(s => agg[s].value/1e6), backgroundColor: stages.map(s => STAGE_COLORS_MAP[s]+'cc'), borderRadius: 4 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend:{display:false}, tooltip:{ callbacks:{ label: ctx => fmt(ctx.parsed.y*1e6) }}},
                scales: { y:{beginAtZero:true, ticks:{callback:v=>v+' M'}, grid:{color:'#21262D'}}, x:{grid:{display:false}} }
            }
        });
    }

    createStageCompareChart() {
        const agg = this.aggByStage();
        const stages = STAGE_ORDER.filter(s => agg[s].count > 0);
        return new Chart(document.getElementById('chart-stage-compare'), {
            type: 'bar',
            data: {
                labels: stages.map(s => STAGE_LABELS[s]),
                datasets: [
                    { label: 'Uppskattat', data: stages.map(s => agg[s].value/1e6), backgroundColor: '#21262D', borderRadius: 4 },
                    { label: 'Viktat', data: stages.map(s => agg[s].weighted/1e6), backgroundColor: '#58A6FFcc', borderRadius: 4 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend:{position:'top',labels:{usePointStyle:true,padding:16,color:'#8B949E'}}, tooltip:{ callbacks:{ label: ctx => ctx.dataset.label+': '+fmt(ctx.parsed.y*1e6) }}},
                scales: { y:{beginAtZero:true, ticks:{callback:v=>v+' M'}, grid:{color:'#21262D'}}, x:{grid:{display:false}} }
            }
        });
    }

    createStackedChart() {
        const stages = STAGE_ORDER.filter(s => this.filteredData.some(d => d.stage === s));
        const datasets = TYPE_ORDER.map(t => ({
            label: TYPE_LABELS[t],
            data: stages.map(s => this.filteredData.filter(d => d.stage===s && d.deal_type===t).reduce((sum,d) => sum+d.estimated_value, 0)/1e6),
            backgroundColor: TYPE_COLORS[t]+'cc', borderRadius: 2
        }));
        return new Chart(document.getElementById('chart-stacked'), {
            type: 'bar',
            data: { labels: stages.map(s => STAGE_LABELS[s]), datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend:{position:'top',labels:{usePointStyle:true,padding:16,color:'#8B949E'}}, tooltip:{ callbacks:{ label: ctx => ctx.dataset.label+': '+fmt(ctx.parsed.y*1e6) }}},
                scales: { x:{stacked:true, grid:{display:false}}, y:{stacked:true, beginAtZero:true, ticks:{callback:v=>v+' M'}, grid:{color:'#21262D'}} }
            }
        });
    }

    // ─── HITRATE MATRIX ───────────────────────────────────
    renderHitrateMatrix() {
        let html = '<table class="matrix-table"><thead><tr><th>Affärstyp</th>';
        STAGE_ORDER.forEach(s => html += '<th style="text-align:center">'+STAGE_LABELS[s]+'</th>');
        html += '</tr></thead><tbody>';
        TYPE_ORDER.forEach(t => {
            html += '<tr><td>'+TYPE_LABELS[t]+'</td>';
            STAGE_ORDER.forEach(s => {
                const hr = HITRATE_MATRIX[t]?.[s] || 0;
                const cls = hr >= 80 ? 'hr-high' : hr >= 40 ? 'hr-mid' : 'hr-low';
                html += '<td style="text-align:center"><span class="hr-cell '+cls+'">'+hr+'%</span></td>';
            });
            html += '</tr>';
        });
        html += '</tbody></table>';
        document.getElementById('hitrate-matrix').innerHTML = html;
    }

    // ─── DEAL TABLE ───────────────────────────────────────
    renderDealTable() {
        const d = [...this.filteredData].sort((a,b) => {
            let av = a[this.sortCol], bv = b[this.sortCol];
            if (this.sortCol === '_weighted') { av = a.estimated_value*a.hit_rate/100; bv = b.estimated_value*b.hit_rate/100; }
            const cmp = av < bv ? -1 : av > bv ? 1 : 0;
            return this.sortDir === 'asc' ? cmp : -cmp;
        });
        document.getElementById('deal-count-badge').textContent = d.length + ' st';
        const cols = [
            {field:'name', label:'Projekt'},
            {field:'stage', label:'Steg'},
            {field:'deal_type', label:'Typ'},
            {field:'estimated_value', label:'Uppskattat'},
            {field:'hit_rate', label:'Hitrate'},
            {field:'_weighted', label:'Viktat'}
        ];
        let html = '<table class="deals-table"><thead><tr>';
        cols.forEach(c => {
            const arrow = this.sortCol === c.field ? (this.sortDir === 'asc' ? ' ▲' : ' ▼') : '';
            const align = ['estimated_value','hit_rate','_weighted'].includes(c.field) ? ' text-right' : '';
            html += `<th class="${align}" onclick="dashboard.sortTable('${c.field}')">${c.label}${arrow}</th>`;
        });
        html += '</tr></thead><tbody>';
        d.forEach(r => {
            const w = r.estimated_value * r.hit_rate / 100;
            html += '<tr>';
            if (r.twenty_id) {
                html += '<td><a href="http://161.35.79.92:3001/object/opportunity/'+r.twenty_id+'" target="_blank" style="color:#58A6FF;text-decoration:none">'+r.name+'</a></td>';
            } else {
                html += '<td>'+r.name+'</td>';
            }
            html += '<td><span class="tag stage-'+r.stage+'">'+(STAGE_LABELS[r.stage]||r.stage)+'</span></td>';
            html += '<td><span class="tag tag-'+r.deal_type+'">'+(TYPE_LABELS[r.deal_type]||r.deal_type)+'</span></td>';
            html += '<td class="text-right mono">'+fmt(r.estimated_value)+'</td>';
            html += '<td class="text-right mono">'+r.hit_rate+'%</td>';
            html += '<td class="text-right mono" style="color:'+(w >= r.estimated_value*0.5 ? '#3FB950' : '#8B949E')+'">'+fmt(w)+'</td>';
            html += '</tr>';
        });
        html += '</tbody></table>';
        document.getElementById('deal-table').innerHTML = html;
    }

    sortTable(field) {
        if (this.sortCol === field) { this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc'; }
        else { this.sortCol = field; this.sortDir = 'desc'; }
        this.renderDealTable();
    }

    // ─── FINANCIALS (Fortnox) ─────────────────────────────
    renderFinancials() {
        document.getElementById('fortnox-section').style.display = 'block';
        const f = FORTNOX;

        const tb1Color = f.tb1 >= 0 ? '#3FB950' : '#F85149';
        const tb1Margin = f.tb1_margin ? f.tb1_margin.toFixed(1) : '0';
        const overdueRecv = f.overdue_receivables || 0;
        const overdueReal = f.overdue_real || 0;
        const overdueLabeled = f.overdue_labeled || 0;
        const overduePay = f.overdue_payables || 0;
        const netCashflow = (f.receivables || 0) - (f.payables || 0);

        // CFO risk classification
        const recvSafe = f.recv_safe || 0;
        const recvRisk = f.recv_risk || 0;
        const recvCritical = f.recv_critical || 0;
        const recvWeighted = f.recv_weighted || 0;

        let recvText = '';
        recvText += '<span style="color:#3FB950">S\u00e4kra: ' + fmt(recvSafe) + '</span>';
        if (recvRisk > 0) recvText += '<br><span style="color:#D29922">Bevakade (50%): ' + fmt(recvRisk) + '</span>';
        if (recvCritical > 0) recvText += '<br><span style="color:#F85149">Kritiska (25%): ' + fmt(recvCritical) + '</span>';
        recvText += '<br><span style="font-size:10px;color:#8B949E">Riskviktat: ' + fmt(recvWeighted) + '</span>';

        var fnxBase = f.app_id ? 'https://apps2.fortnox.se/app/' + f.app_id : '';
        var fnxKfList = fnxBase ? fnxBase + '/kf/invoicelist' : '';
        var fnxLfList = fnxBase ? fnxBase + '/lf/supplierinvoicelist' : '';

        document.getElementById('finance-kpi-row').innerHTML =
            '<div class="kpi-card" style="cursor:pointer" onclick="window.open(\'' + fnxKfList + '\',\'_blank\')">' +
                '<div class="kpi-label">Fakturerad oms\u00e4ttning</div>' +
                '<div class="kpi-value">' + fmt(f.net_revenue || 0) + '</div>' +
                '<div class="kpi-subtext">' + (f.invoice_count || 0) + ' fakturor' + (f.credit_notes ? ' (kreditnotor: ' + fmt(Math.abs(f.credit_notes)) + ')' : '') + '</div>' +
            '</div>' +
            '<div class="kpi-card" style="cursor:pointer" onclick="window.open(\'' + fnxKfList + '\',\'_blank\')">' +
                '<div class="kpi-label">TB1</div>' +
                '<div class="kpi-value" style="color:' + tb1Color + '">' + fmt(f.tb1 || 0) + '</div>' +
                '<div class="kpi-subtext">Marginal: ' + tb1Margin + '% \u00b7 Lev.kostnader: ' + fmt(f.supplier_costs || 0) + '</div>' +
                '<div class="progress-bar" style="margin-top:12px"><div class="progress-fill" style="width:' + Math.min(Math.max(f.tb1_margin||0,0),100) + '%;background:' + tb1Color + '"></div></div>' +
            '</div>' +
            '<div class="kpi-card" style="cursor:pointer" onclick="window.open(\'' + fnxKfList + '\',\'_blank\')">' +
                '<div class="kpi-label">Kundfordringar</div>' +
                '<div class="kpi-value">' + fmt(f.receivables || 0) + '</div>' +
                '<div class="kpi-subtext">' + recvText + '</div>' +
            '</div>' +
            '<div class="kpi-card" style="cursor:pointer" onclick="window.open(\'' + fnxLfList + '\',\'_blank\')">' +
                '<div class="kpi-label">Leverant\u00f6rsskulder</div>' +
                '<div class="kpi-value text-orange">' + fmt(f.payables || 0) + '</div>' +
                '<div class="kpi-subtext">' +
                    ((f.si_parkerad_count || 0) > 0 ? '<span style="color:#D29922">Parkerade: ' + fmt(f.si_parkerad_total || 0) + '</span><br>' : '') +
                    ((f.si_overdue_unlabeled_count || 0) > 0 ? '<span style="color:#F85149">F\u00f6rfallna: ' + fmt(f.si_overdue_unlabeled_total || 0) + '</span><br>' : '') +
                    (f.supplier_invoice_count || 0) + ' fakturor' +
                '</div>' +
            '</div>';

        // Top customers table
        if (f.top_customers && f.top_customers.length) {
            var h = '<table class="deals-table"><thead><tr><th>Kund</th><th class="text-right">Belopp</th><th class="text-right">Antal</th></tr></thead><tbody>';
            f.top_customers.forEach(function(c) {
                h += '<tr><td>' + c.name + '</td><td class="text-right mono">' + fmt(c.total) + '</td><td class="text-right mono">' + c.count + '</td></tr>';
            });
            h += '</tbody></table>';
            document.getElementById('top-customers-table').innerHTML = h;
        }

        // Top suppliers table
        if (f.top_suppliers && f.top_suppliers.length) {
            var h2 = '<table class="deals-table"><thead><tr><th>Leverant\u00f6r</th><th class="text-right">Belopp</th><th class="text-right">Antal</th></tr></thead><tbody>';
            f.top_suppliers.forEach(function(s) {
                h2 += '<tr><td>' + s.name + '</td><td class="text-right mono">' + fmt(s.total) + '</td><td class="text-right mono">' + s.count + '</td></tr>';
            });
            h2 += '</tbody></table>';
            document.getElementById('top-suppliers-table').innerHTML = h2;
        }

        // Overdue customer invoices table with labels
        var overdueEl = document.getElementById('overdue-invoices-table');
        if (f.overdue_invoices && f.overdue_invoices.length) {
            var h3 = '<table class="deals-table"><thead><tr><th>Faktura</th><th>Kund</th><th>F\u00f6rfallodag</th><th class="text-right">Saldo</th><th>Etikett</th></tr></thead><tbody>';
            f.overdue_invoices.forEach(function(inv) {
                var labelTag = inv.label ? '<span class="tag" style="background:rgba(210,153,34,0.15);color:#D29922">' + inv.label + '</span>' : '<span style="color:#F85149;font-size:11px">Ej markerad</span>';
                var fnxLink = f.app_id ? '<a href="https://apps2.fortnox.se/app/' + f.app_id + '/kf/invoice/' + inv.fortnox_id + '" target="_blank" style="color:#58A6FF;text-decoration:none">' + inv.fortnox_id + '</a>' : inv.fortnox_id;
                h3 += '<tr><td>' + fnxLink + '</td><td>' + inv.customer_name + '</td><td>' + inv.due_date + '</td><td class="text-right mono">' + fmt(inv.balance) + '</td><td>' + labelTag + '</td></tr>';
            });
            h3 += '</tbody></table>';
            overdueEl.innerHTML = h3;
        } else {
            overdueEl.innerHTML = '<p style="color:#8B949E;font-size:13px;padding:12px">Inga f\u00f6rfallna kundfakturor</p>';
        }

        // Supplier invoices by label — Parkerade, Bevakade, Förfallna
        var allSi = f.all_supplier_invoices || [];
        var siParkerad = allSi.filter(function(i) { return i.label === 'Parkerad'; });
        var siBevakas = allSi.filter(function(i) { return i.label === 'Bevakas'; });
        var siOverdue = allSi.filter(function(i) { return i.is_overdue && !i.label; });

        function renderSiTable(items, elId, emptyMsg) {
            var el = document.getElementById(elId);
            if (!el) return;
            if (items.length === 0) {
                el.innerHTML = '<p style="color:#8B949E;font-size:13px;padding:12px">' + emptyMsg + '</p>';
                return;
            }
            var h = '<table class="deals-table"><thead><tr><th>Faktura</th><th>Leverant\u00f6r</th><th>F\u00f6rfallodag</th><th class="text-right">Saldo</th><th>Etikett</th></tr></thead><tbody>';
            items.forEach(function(inv) {
                var siLink = f.app_id ? '<a href="https://apps2.fortnox.se/app/' + f.app_id + '/lf/supplierinvoice/' + inv.fortnox_id + '" target="_blank" style="color:#58A6FF;text-decoration:none">' + inv.fortnox_id + '</a>' : inv.fortnox_id;
                var labelSelect = '<select onchange="setSupplierLabel(\'' + inv.fortnox_id + '\', this.value)" style="background:#161B22;color:#C9D1D9;border:1px solid #30363D;border-radius:4px;padding:2px 4px;font-size:11px;cursor:pointer">' +
                    '<option value=""' + (!inv.label ? ' selected' : '') + '>—</option>' +
                    '<option value="Parkerad"' + (inv.label === 'Parkerad' ? ' selected' : '') + '>Parkerad</option>' +
                    '<option value="Bevakas"' + (inv.label === 'Bevakas' ? ' selected' : '') + '>Bevakas</option>' +
                    '<option value="Tvist"' + (inv.label === 'Tvist' ? ' selected' : '') + '>Tvist</option>' +
                    '</select>';
                h += '<tr><td>' + siLink + '</td><td>' + inv.supplier_name + '</td><td>' + inv.due_date + '</td><td class="text-right mono">' + fmt(inv.balance) + '</td><td>' + labelSelect + '</td></tr>';
            });
            h += '</tbody></table>';
            el.innerHTML = h;
        }

        renderSiTable(siParkerad, 'si-parkerad-table', 'Inga parkerade leverant\u00f6rsfakturor');
        renderSiTable(siBevakas, 'si-bevakas-table', 'Inga bevakade leverant\u00f6rsfakturor');
        renderSiTable(siOverdue, 'si-overdue-table', 'Inga f\u00f6rfallna leverant\u00f6rsfakturor utan etikett');

        // Badges
        var pBadge = document.getElementById('si-parkerad-badge');
        if (pBadge) pBadge.textContent = siParkerad.length > 0 ? siParkerad.length + ' st \u00b7 ' + fmt(f.si_parkerad_total || 0) : '';
        var bBadge = document.getElementById('si-bevakas-badge');
        if (bBadge) bBadge.textContent = siBevakas.length > 0 ? siBevakas.length + ' st \u00b7 ' + fmt(f.si_bevakas_total || 0) : '';
        var oBadge = document.getElementById('si-overdue-badge');
        if (oBadge) oBadge.textContent = siOverdue.length > 0 ? siOverdue.length + ' st \u00b7 ' + fmt(f.si_overdue_unlabeled_total || 0) : '';

        // Cashflow chart
        this.charts.cashflow = new Chart(document.getElementById('chart-cashflow'), {
            type: 'bar',
            data: {
                labels: ['Kundfordringar', 'Lev.skulder', 'Netto'],
                datasets: [{
                    data: [f.receivables || 0, -(f.payables || 0), netCashflow],
                    backgroundColor: [
                        'rgba(88,166,255,0.7)',
                        'rgba(249,115,22,0.7)',
                        netCashflow >= 0 ? 'rgba(63,185,80,0.7)' : 'rgba(248,81,73,0.7)'
                    ],
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend:{display:false}, tooltip:{ callbacks:{ label: function(ctx) { return fmt(Math.abs(ctx.parsed.y)); } }}},
                scales: { y:{ticks:{callback:function(v){return fmtShort(Math.abs(v));}}, grid:{color:'#21262D'}}, x:{grid:{display:false}} }
            }
        });

        // TB1 doughnut
        this.charts.tb1 = new Chart(document.getElementById('chart-tb1'), {
            type: 'doughnut',
            data: {
                labels: ['TB1 (marginal)', 'Lev.kostnader'],
                datasets: [{
                    data: [Math.max(f.tb1||0, 0), f.supplier_costs||0],
                    backgroundColor: ['rgba(63,185,80,0.8)', 'rgba(249,115,22,0.5)'],
                    borderColor: ['#3FB950', '#F97316'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend:{position:'bottom',labels:{usePointStyle:true,padding:16,color:'#8B949E'}},
                    tooltip:{ callbacks:{ label: function(ctx) { return ctx.label + ': ' + fmt(ctx.parsed); } }}
                }
            }
        });
    }


    // ─── LIQUIDITY FORECAST ─────────────────────────────
    renderForecast(numWeeks) {
        numWeeks = numWeeks || 8;
        document.getElementById('forecast-section').style.display = 'block';
        const f = FORTNOX;
        const weeks = (f.forecast_weeks || []).slice(0, numWeeks);
        if (!weeks.length) return;

        const labels = weeks.map(w => w.label);
        // Risk-weighted: only count what we realistically expect to receive/pay
        const inData = weeks.map(w => w.inbetalningar_viktat || w.inbetalningar);
        const inDataRaw = weeks.map(w => w.inbetalningar);
        const utData = weeks.map(w => -(w.utbetalningar_justerat || w.utbetalningar));
        const utDataRaw = weeks.map(w => -w.utbetalningar);

        // Cumulative cash (risk-weighted)
        let cumulative = [];
        let running = 0;
        for (let i = 0; i < weeks.length; i++) {
            running += (weeks[i].inbetalningar_viktat || weeks[i].inbetalningar) - (weeks[i].utbetalningar_justerat || weeks[i].utbetalningar);
            cumulative.push(running);
        }
        // Cumulative cash (raw/optimistic for comparison)
        let cumulativeRaw = [];
        let runningRaw = 0;
        for (let i = 0; i < weeks.length; i++) {
            runningRaw += weeks[i].inbetalningar - weeks[i].utbetalningar;
            cumulativeRaw.push(runningRaw);
        }

        // Update label
        document.getElementById('forecast-weeks-label').textContent = numWeeks + ' veckor';

        // Alert badge (based on risk-weighted cumulative)
        const alertEl = document.getElementById('forecast-alert-badge');
        const minCash = Math.min(...cumulative);
        const hasNegWeek = cumulative.some(v => v < 0);
        if (hasNegWeek) {
            alertEl.style.display = 'inline-block';
            alertEl.style.background = '#F85149';
            alertEl.style.color = '#fff';
            alertEl.textContent = 'Varning — negativt kassafl\u00f6de';
        } else if (minCash < 200000) {
            alertEl.style.display = 'inline-block';
            alertEl.style.background = '#D29922';
            alertEl.style.color = '#0D1117';
            alertEl.textContent = 'Uppmarksamhet';
        } else {
            alertEl.style.display = 'none';
        }

        // Summary with both raw and weighted
        const totalInW = weeks.reduce((s,w) => s + (w.inbetalningar_viktat || w.inbetalningar), 0);
        const totalUtA = weeks.reduce((s,w) => s + (w.utbetalningar_justerat || w.utbetalningar), 0);
        const totalInRaw = weeks.reduce((s,w) => s + w.inbetalningar, 0);
        const totalUtRaw = weeks.reduce((s,w) => s + w.utbetalningar, 0);
        const nettoW = totalInW - totalUtA;
        document.getElementById('forecast-summary').innerHTML =
            '<b>Riskviktat:</b> In: <span style="color:#3FB950">' + fmt(totalInW) + '</span> | Ut: <span style="color:#F85149">' + fmt(totalUtA) + '</span> | <b>Netto: <span style="color:' + (nettoW >= 0 ? '#3FB950' : '#F85149') + '">' + fmt(nettoW) + '</span></b>' +
            '<br><span style="font-size:11px;color:#8B949E">Oviktat: In ' + fmt(totalInRaw) + ' | Ut ' + fmt(totalUtRaw) + ' | Netto ' + fmt(totalInRaw - totalUtRaw) + '</span>';

        // Toggle buttons
        document.querySelectorAll('.forecast-toggle').forEach(function(btn) {
            btn.classList.toggle('active', parseInt(btn.dataset.weeks) === numWeeks);
        });

        // Destroy old chart
        if (this.charts.forecast) this.charts.forecast.destroy();

        this.charts.forecast = new Chart(document.getElementById('chart-forecast'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Inbetalningar',
                        data: inData,
                        backgroundColor: 'rgba(63,185,80,0.7)',
                        borderRadius: 4,
                        order: 2
                    },
                    {
                        label: 'Utbetalningar',
                        data: utData,
                        backgroundColor: 'rgba(248,81,73,0.55)',
                        borderRadius: 4,
                        order: 2
                    },
                    {
                        label: 'Kumulativ kassa (riskviktad)',
                        data: cumulative,
                        type: 'line',
                        borderColor: '#58A6FF',
                        backgroundColor: 'rgba(88,166,255,0.1)',
                        borderWidth: 2.5,
                        pointRadius: 3,
                        pointBackgroundColor: '#58A6FF',
                        fill: false,
                        tension: 0.3,
                        order: 1,
                        yAxisID: 'y'
                    },
                    {
                        label: 'Kumulativ kassa (oviktad)',
                        data: cumulativeRaw,
                        type: 'line',
                        borderColor: 'rgba(210,153,34,0.75)',
                        borderWidth: 2,
                        borderDash: [6, 4],
                        pointRadius: 2,
                        pointBackgroundColor: 'rgba(210,153,34,0.75)',
                        fill: false,
                        tension: 0.3,
                        order: 1,
                        yAxisID: 'y'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { usePointStyle: true, padding: 20, color: '#8B949E', font: { size: 12 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                var val = Math.abs(ctx.parsed.y);
                                return ctx.dataset.label + ': ' + fmtShort(val);
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#8B949E', font: { size: 11 } }
                    },
                    y: {
                        grid: { color: '#21262D' },
                        ticks: {
                            color: '#8B949E',
                            callback: function(v) { return fmtShort(Math.abs(v)); }
                        }
                    }
                }
            },
            plugins: [{
                id: 'zeroLine',
                afterDraw: function(chart) {
                    var yScale = chart.scales.y;
                    var ctx2 = chart.ctx;
                    var yZero = yScale.getPixelForValue(0);
                    ctx2.save();
                    ctx2.setLineDash([6, 4]);
                    ctx2.strokeStyle = 'rgba(248,81,73,0.4)';
                    ctx2.lineWidth = 1;
                    ctx2.beginPath();
                    ctx2.moveTo(chart.chartArea.left, yZero);
                    ctx2.lineTo(chart.chartArea.right, yZero);
                    ctx2.stroke();
                    ctx2.restore();
                }
            }]
        });
    }

    setForecastWeeks(n) {
        this.renderForecast(n);
    }
    renderProjects() {
        const projects = FORTNOX.projects || [];
        const groups = FORTNOX.project_groups || [];
        const container = document.getElementById('projects-container');
        const empty = document.getElementById('projects-empty');
        
        if ((!projects || projects.length === 0) && (!groups || groups.length === 0)) {
            container.style.display = 'none';
            empty.style.display = 'block';
            return;
        }
        
        container.style.display = 'block';
        empty.style.display = 'none';
        
        // Render grouped view
        const gtbody = document.getElementById('project-groups-tbody');
        if (gtbody && groups.length > 0) {
            gtbody.innerHTML = '';
            groups.forEach(function(g) {
                const tb1Color = g.tb1 >= 0 ? '#3FB950' : '#F85149';
                const row = document.createElement('tr');
                row.innerHTML = 
                    '<td><strong>' + (g.group_name || '-') + '</strong></td>' +
                    '<td style="color:#8B949E;font-size:12px">' + (g.leaders || '-') + '</td>' +
                    '<td class="text-right mono">' + fmt(g.net_revenue || 0) + '</td>' +
                    '<td class="text-right mono">' + fmt(g.supplier_costs || 0) + '</td>' +
                    '<td class="text-right mono" style="color:' + tb1Color + '"><strong>' + fmt(g.tb1 || 0) + '</strong></td>' +
                    '<td class="text-right mono" style="color:' + tb1Color + '"><strong>' + (parseFloat(g.tb1_margin) || 0).toFixed(1) + '%</strong></td>' +
                    '<td class="text-right mono">' + (g.invoice_count || 0) + ' / ' + (g.supplier_invoice_count || 0) + '</td>';
                gtbody.appendChild(row);
            });
        }
        
        // Render detail view
        const tbody = document.getElementById('projects-tbody');
        tbody.innerHTML = '';
        
        projects.forEach(function(p) {
            const tb1Color = p.tb1 >= 0 ? '#3FB950' : '#F85149';
            const row = document.createElement('tr');
            row.innerHTML = 
                '<td><strong>' + p.project_number + '</strong></td>' +
                '<td>' + (p.project_name || '-') + '</td>' +
                '<td style="color:#8B949E">' + (p.project_group || '-') + '</td>' +
                '<td style="color:#8B949E;font-size:12px">' + (p.project_leader || '-') + '</td>' +
                '<td class="text-right mono">' + fmt(p.net_revenue || 0) + '</td>' +
                '<td class="text-right mono">' + fmt(p.supplier_costs || 0) + '</td>' +
                '<td class="text-right mono" style="color:' + tb1Color + '"><strong>' + fmt(p.tb1 || 0) + '</strong></td>' +
                '<td class="text-right mono" style="color:' + tb1Color + '"><strong>' + (parseFloat(p.tb1_margin) || 0).toFixed(1) + '%</strong></td>' +
                '<td class="text-right mono">' + (p.invoice_count || 0) + ' / ' + (p.supplier_invoice_count || 0) + '</td>';
            tbody.appendChild(row);
        });
    }


}

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
const dashboard = new Dashboard(DEALS);
window._dashboard = dashboard;
</script>
</body>
</html>
